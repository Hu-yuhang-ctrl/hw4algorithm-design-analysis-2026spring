        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\ndirection LR\n\nclass 用户 {\n  &lt;&lt;valueObject&gt;&gt;\n  +用户编号: Long\n  +用户名: String\n  +用户角色: String\n  +用户状态: 用户状态\n  +登录时间: DateTime\n  +进入系统(): void\n  +退出系统(): void\n}\n\nclass 普通用户 {\n  &lt;&lt;actor&gt;&gt;\n  +找房需求: String\n  +预测需求: String\n  +查询房源(): void\n  +提交预测请求(): void\n}\n\nclass 数据维护人员 {\n  &lt;&lt;actor&gt;&gt;\n  +维护范围: String\n  +维护任务状态: String\n  +核查房源资料(): void\n  +更新房源资料(): void\n}\n\nclass 系统管理员 {\n  &lt;&lt;actor&gt;&gt;\n  +管理范围: String\n  +异常处理状态: String\n  +查看系统状态(): void\n  +处理异常信息(): void\n}\n\nclass 用户状态 {\n  &lt;&lt;enumeration&gt;&gt;\n  启用\n  禁用\n  待定\n}\n\n普通用户 --|&gt; 用户 : 泛化\n数据维护人员 --|&gt; 用户 : 泛化\n系统管理员 --|&gt; 用户 : 泛化\n用户 ..&gt; 用户状态 : 使用\n\n\nclass 首页展示界面 {\n  &lt;&lt;boundary&gt;&gt;\n  +当前页码: Integer\n  +每页数量: Integer\n  +当前城市: String\n  +显示房源概况(): void\n  +显示城市统计结果(统计结果: 统计结果): void\n  +显示价格趋势(统计结果: 统计结果): void\n  +显示区域分布(统计结果: 统计结果): void\n}\n\nclass 房源查询界面 {\n  &lt;&lt;boundary&gt;&gt;\n  +当前页码: Integer\n  +每页数量: Integer\n  +当前筛选条件: 房源筛选条件\n  +显示查询页面(): void\n  +接收查询条件(筛选条件: 房源筛选条件): void\n  +显示房源列表(房源列表: List~房源~): void\n  +显示房源详情(房源: 房源): void\n  +显示位置与周边配套(房源: 房源): void\n}\n\nclass 房价预测界面 {\n  &lt;&lt;boundary&gt;&gt;\n  +页面标题: String\n  +当前预测请求: 预测请求\n  +显示预测表单(): void\n  +接收房源特征(预测请求: 预测请求): void\n  +显示预测结果(预测结果: 预测结果): void\n  +显示结果说明(说明: String): void\n}\n\nclass 房源维护界面 {\n  &lt;&lt;boundary&gt;&gt;\n  +当前维护范围: String\n  +资料状态: 资料状态\n  +显示维护页面(): void\n  +接收维护范围(维护范围: String): void\n  +显示待核查资料(资料列表: List~房源维护资料~): void\n  +提交资料核查结果(核查结果: 房源资料核查结果): void\n  +提交房源更新信息(更新记录: 房源资料更新记录): void\n}\n\nclass 系统基础管理界面 {\n  &lt;&lt;boundary&gt;&gt;\n  +当前管理事项: String\n  +当前操作人员: 系统管理员\n  +显示管理事项(): void\n  +显示系统状态(系统状态: 系统状态): void\n  +显示基础业务配置(配置列表: List~基础业务配置~): void\n  +显示用户与权限信息(权限信息: 用户与权限信息): void\n  +显示异常信息(异常信息: 异常信息): void\n}\n\n\nclass 统计分析控制类 {\n  &lt;&lt;control&gt;&gt;\n  +获取首页统计结果(): 统计结果\n  +获取城市统计结果(城市名称: String): 统计结果\n  +获取区域统计结果(地区名称: String): 统计结果\n}\n\nclass 房源查询控制类 {\n  &lt;&lt;control&gt;&gt;\n  +查询房源(筛选条件: 房源筛选条件): List~房源~\n  +查看房源详情(房源编号: Long): 房源\n  +查看位置与周边配套(房源编号: Long): String\n}\n\nclass 房价预测控制类 {\n  &lt;&lt;control&gt;&gt;\n  +提交预测请求(预测请求: 预测请求): 预测结果\n  +检查预测条件(预测请求: 预测请求): Boolean\n  +返回预测结果(预测结果: 预测结果): void\n}\n\nclass 房源维护控制类 {\n  &lt;&lt;control&gt;&gt;\n  +确定维护范围(维护范围: String): List~房源维护资料~\n  +核查房源资料(房源资料: 房源维护资料): 房源资料核查结果\n  +补充房源资料(房源资料: 房源维护资料): Boolean\n  +整理房源资料(房源资料: 房源维护资料): Boolean\n  +处理异常资料(异常资料: 异常资料): Boolean\n  +更新房源信息(更新记录: 房源资料更新记录): Boolean\n}\n\nclass 系统基础管理控制类 {\n  &lt;&lt;control&gt;&gt;\n  +查看系统状态(): 系统状态\n  +维护基础业务配置(配置项: 基础业务配置): Boolean\n  +管理用户与权限(权限信息: 用户与权限信息): Boolean\n  +处理异常信息(异常信息: 异常信息): Boolean\n}\n\n\nclass 房源查询服务类 {\n  &lt;&lt;service&gt;&gt;\n  +根据条件筛选房源(筛选条件: 房源筛选条件): List~房源~\n  +获取房源详情(房源编号: Long): 房源\n  +获取房源配套信息(房源编号: Long): String\n}\n\nclass 统计分析服务类 {\n  &lt;&lt;service&gt;&gt;\n  +统计房源数量(): Integer\n  +统计平均价格(): Double\n  +统计区域分布(): Map~String,Integer~\n  +统计价格趋势(): List~统计结果~\n}\n\nclass 房价预测服务类 {\n  &lt;&lt;service&gt;&gt;\n  +校验预测请求(预测请求: 预测请求): Boolean\n  +生成预测结果(预测请求: 预测请求): 预测结果\n  +生成结果说明(预测结果: 预测结果): String\n}\n\nclass 房源资料核查服务类 {\n  &lt;&lt;service&gt;&gt;\n  +检查完整性(房源资料: 房源维护资料): Boolean\n  +检查格式规范性(房源资料: 房源维护资料): Boolean\n  +检查数值合理性(房源资料: 房源维护资料): Boolean\n  +检查重复性(房源资料: 房源维护资料): Boolean\n  +生成核查结果(房源资料: 房源维护资料): 房源资料核查结果\n}\n\nclass 房源资料更新服务类 {\n  &lt;&lt;service&gt;&gt;\n  +校验更新信息(更新记录: 房源资料更新记录): Boolean\n  +保存更新信息(更新记录: 房源资料更新记录): Boolean\n  +生成更新记录(更新记录: 房源资料更新记录): 房源资料更新记录\n}\n\nclass 基础业务配置服务类 {\n  &lt;&lt;service&gt;&gt;\n  +新增配置项(配置项: 基础业务配置): Boolean\n  +修改配置项(配置项: 基础业务配置): Boolean\n  +停用配置项(配置编号: Long): Boolean\n  +检查配置有效性(配置项: 基础业务配置): Boolean\n}\n\nclass 用户权限服务类 {\n  &lt;&lt;service&gt;&gt;\n  +新增用户(权限信息: 用户与权限信息): Boolean\n  +调整用户权限(权限信息: 用户与权限信息): Boolean\n  +启用或禁用用户(用户编号: Long, 用户状态: 用户状态): Boolean\n  +检查权限配置(权限信息: 用户与权限信息): Boolean\n}\n\nclass 异常信息服务类 {\n  &lt;&lt;service&gt;&gt;\n  +获取异常列表(): List~异常信息~\n  +确认异常原因(异常信息: 异常信息): String\n  +处理异常信息(异常信息: 异常信息): Boolean\n  +更新异常状态(异常编号: Long, 处理状态: String): Boolean\n}\n\n\nclass 城市 {\n  &lt;&lt;entity&gt;&gt;\n  +城市编号: Long\n  +城市名称: String\n  +房源数量: Integer\n  +平均价格: Double\n  +统计城市房源(): 统计结果\n}\n\nclass 地区 {\n  &lt;&lt;entity&gt;&gt;\n  +地区编号: Long\n  +地区名称: String\n  +所属城市: String\n  +房源数量: Integer\n  +价格水平: Double\n  +统计地区房源(): 统计结果\n}\n\nclass 小区 {\n  &lt;&lt;entity&gt;&gt;\n  +小区编号: Long\n  +小区名称: String\n  +所属地区: String\n  +房源数量: Integer\n  +归集房源(): List~房源~\n}\n\nclass 房源 {\n  &lt;&lt;entity&gt;&gt;\n  +房源编号: Long\n  +房源名称: String\n  +城市名称: String\n  +地区名称: String\n  +小区名称: String\n  +总价: Double\n  +单价: Double\n  +面积: Double\n  +户型: String\n  +楼层: String\n  +朝向: String\n  +装修: String\n  +经度: Double\n  +纬度: Double\n  +房源状态: 房源状态\n  +展示房源信息(): String\n  +参与价格参考(): Boolean\n}\n\nclass 房源状态 {\n  &lt;&lt;enumeration&gt;&gt;\n  可展示\n  待完善\n  异常\n  已停用\n}\n\nclass 房源筛选条件 {\n  &lt;&lt;valueObject&gt;&gt;\n  +城市名称: String\n  +地区名称: String\n  +最低总价: Double\n  +最高总价: Double\n  +最低面积: Double\n  +最高面积: Double\n  +户型要求: String\n  +装修要求: String\n  +是否有效(): Boolean\n}\n\nclass 统计结果 {\n  &lt;&lt;entity&gt;&gt;\n  +统计编号: Long\n  +统计对象: String\n  +统计类型: String\n  +统计数值: Double\n  +生成时间: DateTime\n  +生成统计说明(): String\n}\n\nclass 预测请求 {\n  &lt;&lt;entity&gt;&gt;\n  +请求编号: Long\n  +城市名称: String\n  +地区名称: String\n  +面积: Double\n  +户型: String\n  +楼层: String\n  +朝向: String\n  +装修: String\n  +请求状态: String\n  +提交时间: DateTime\n  +检查信息完整性(): Boolean\n  +检查信息合理性(): Boolean\n}\n\nclass 预测结果 {\n  &lt;&lt;entity&gt;&gt;\n  +结果编号: Long\n  +参考价格: Double\n  +价格区间: String\n  +结果说明: String\n  +反馈状态: String\n  +生成时间: DateTime\n  +反馈参考价格(): String\n  +说明预测结果(): String\n}\n\nclass 价格模型 {\n  &lt;&lt;entity&gt;&gt;\n  +模型编号: Long\n  +模型名称: String\n  +模型版本: String\n  +训练时间: DateTime\n  +模型状态: String\n  +加载模型(): Boolean\n  +输出预测价格(预测请求: 预测请求): Double\n}\n\nclass 模型报告 {\n  &lt;&lt;entity&gt;&gt;\n  +报告编号: Long\n  +模型名称: String\n  +样本数量: Integer\n  +平均绝对误差: Double\n  +均方根误差: Double\n  +决定系数: Double\n  +生成报告(): String\n}\n\nclass 房源维护资料 {\n  &lt;&lt;entity&gt;&gt;\n  +资料编号: Long\n  +资料来源: String\n  +资料状态: 资料状态\n  +完整性情况: String\n  +规范性情况: String\n  +异常说明: String\n  +更新时间: DateTime\n  +接受核查(): 房源资料核查结果\n  +接受整理(): Boolean\n  +形成标准房源(): 房源\n}\n\nclass 资料状态 {\n  &lt;&lt;enumeration&gt;&gt;\n  待维护\n  待核查\n  待整理\n  异常待处理\n  可用\n  不可用\n}\n\nclass 异常资料 {\n  &lt;&lt;entity&gt;&gt;\n  +异常编号: Long\n  +异常原因: String\n  +异常状态: String\n  +处理结果: String\n  +发现时间: DateTime\n  +标记异常(): void\n  +确认异常(): String\n  +处理异常(): Boolean\n}\n\nclass 房源资料核查结果 {\n  &lt;&lt;entity&gt;&gt;\n  +核查编号: Long\n  +资料编号: Long\n  +是否缺失: Boolean\n  +是否不规范: Boolean\n  +是否异常: Boolean\n  +是否重复: Boolean\n  +核查说明: String\n  +核查时间: DateTime\n  +输出核查结果(): String\n}\n\nclass 房源资料更新记录 {\n  &lt;&lt;entity&gt;&gt;\n  +更新编号: Long\n  +资料编号: Long\n  +更新前内容: String\n  +更新后内容: String\n  +维护人员: String\n  +更新时间: DateTime\n  +更新结果: String\n  +生成更新记录(): String\n}\n\nclass 系统状态 {\n  &lt;&lt;entity&gt;&gt;\n  +状态编号: Long\n  +运行情况: String\n  +异常提示: String\n  +可用状态: Boolean\n  +检查时间: DateTime\n  +反馈运行情况(): String\n  +提示异常信息(): List~异常信息~\n}\n\nclass 基础业务配置 {\n  &lt;&lt;entity&gt;&gt;\n  +配置编号: Long\n  +配置名称: String\n  +配置值: String\n  +配置说明: String\n  +配置状态: String\n  +创建时间: DateTime\n  +检查配置有效性(): Boolean\n  +更新配置(): Boolean\n}\n\nclass 用户与权限信息 {\n  &lt;&lt;entity&gt;&gt;\n  +用户编号: Long\n  +用户账号: String\n  +用户姓名: String\n  +角色名称: String\n  +权限范围: String\n  +用户状态: 用户状态\n  +检查用户信息(): Boolean\n  +检查权限配置(): Boolean\n  +保存权限调整(): Boolean\n}\n\nclass 异常信息 {\n  &lt;&lt;entity&gt;&gt;\n  +异常编号: Long\n  +异常来源: String\n  +异常原因: String\n  +异常级别: String\n  +处理状态: String\n  +处理说明: String\n  +发生时间: DateTime\n  +确认异常原因(): String\n  +记录处理结果(): Boolean\n}\n\n\n首页展示界面 ..&gt; 统计分析控制类 : 依赖\n房源查询界面 ..&gt; 房源查询控制类 : 依赖\n房价预测界面 ..&gt; 房价预测控制类 : 依赖\n房源维护界面 ..&gt; 房源维护控制类 : 依赖\n系统基础管理界面 ..&gt; 系统基础管理控制类 : 依赖\n\n统计分析控制类 ..&gt; 统计分析服务类 : 依赖\n房源查询控制类 ..&gt; 房源查询服务类 : 依赖\n房价预测控制类 ..&gt; 房价预测服务类 : 依赖\n房源维护控制类 ..&gt; 房源资料核查服务类 : 依赖\n房源维护控制类 ..&gt; 房源资料更新服务类 : 依赖\n系统基础管理控制类 ..&gt; 基础业务配置服务类 : 依赖\n系统基础管理控制类 ..&gt; 用户权限服务类 : 依赖\n系统基础管理控制类 ..&gt; 异常信息服务类 : 依赖\n\n统计分析服务类 ..&gt; 房源 : 依赖\n统计分析服务类 ..&gt; 统计结果 : 生成\n统计分析控制类 ..&gt; 统计结果 : 返回\n首页展示界面 ..&gt; 统计结果 : 展示\n\n房源查询服务类 ..&gt; 房源 : 依赖\n房源查询服务类 ..&gt; 房源筛选条件 : 使用\n房源查询控制类 ..&gt; 房源筛选条件 : 使用\n\n房价预测服务类 ..&gt; 预测请求 : 依赖\n房价预测服务类 ..&gt; 预测结果 : 生成\n房价预测服务类 ..&gt; 价格模型 : 依赖\n\n房源资料核查服务类 ..&gt; 房源维护资料 : 依赖\n房源资料核查服务类 ..&gt; 房源资料核查结果 : 生成\n房源资料更新服务类 ..&gt; 房源维护资料 : 依赖\n房源资料更新服务类 ..&gt; 房源资料更新记录 : 生成\n\n基础业务配置服务类 ..&gt; 基础业务配置 : 依赖\n用户权限服务类 ..&gt; 用户与权限信息 : 依赖\n异常信息服务类 ..&gt; 异常信息 : 依赖\n\n城市 \&quot;1\&quot; o-- \&quot;0..*\&quot; 地区 : 聚合\n地区 \&quot;1\&quot; o-- \&quot;0..*\&quot; 小区 : 聚合\n小区 \&quot;1\&quot; o-- \&quot;0..*\&quot; 房源 : 聚合\n\n城市 ..&gt; 统计结果 : 生成\n地区 ..&gt; 统计结果 : 生成\n房源 ..&gt; 房源状态 : 使用\n\n预测请求 \&quot;1\&quot; *-- \&quot;0..1\&quot; 预测结果 : 组合\n价格模型 ..&gt; 预测请求 : 使用\n价格模型 ..&gt; 预测结果 : 生成\n价格模型 ..&gt; 模型报告 : 生成\n\n房源维护资料 \&quot;1\&quot; *-- \&quot;0..*\&quot; 异常资料 : 组合\n房源维护资料 ..&gt; 房源 : 形成\n房源维护资料 ..&gt; 资料状态 : 使用\n房源维护资料 ..&gt; 房源资料核查结果 : 生成\n房源维护资料 ..&gt; 房源资料更新记录 : 生成\n房源维护界面 ..&gt; 资料状态 : 显示\n\n系统管理员 ..&gt; 系统状态 : 查看\n系统管理员 ..&gt; 基础业务配置 : 维护\n系统管理员 ..&gt; 用户与权限信息 : 管理\n系统管理员 ..&gt; 异常信息 : 处理\n\n系统状态 ..&gt; 异常信息 : 提示\n用户与权限信息 ..&gt; 用户状态 : 使用\n\n数据维护人员 ..&gt; 房源维护资料 : 维护\n普通用户 ..&gt; 房源筛选条件 : 设置\n普通用户 ..&gt; 预测请求 : 提交&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="rvZjHZs7JUC4JIlDZKwR-625">
