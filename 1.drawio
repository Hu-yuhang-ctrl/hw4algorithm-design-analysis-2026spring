        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\ndirection LR\n\nclass 用户 {\n  &lt;&lt;actor&gt;&gt;\n  +用户编号: Long\n  +用户名: String\n  +用户角色: String\n  +进入系统(): void\n  +退出系统(): void\n}\n\nclass 普通用户 {\n  &lt;&lt;actor&gt;&gt;\n  +找房需求: String\n  +查询房源(): void\n  +查看房源详情(): void\n  +查看位置与周边配套(): void\n}\n\n用户 &lt;|-- 普通用户 : 泛化\n\n\nclass 首页展示界面 {\n  &lt;&lt;boundary&gt;&gt;\n  +当前省份: String\n  +当前城市: String\n  +显示房源概况(): void\n  +显示统计结果(统计结果: 统计结果): void\n  +显示价格趋势(统计结果: 统计结果): void\n  +显示区域分布(统计结果: 统计结果): void\n}\n\nclass 房源查询界面 {\n  &lt;&lt;boundary&gt;&gt;\n  +当前页码: Integer\n  +每页数量: Integer\n  +当前筛选条件: 房源筛选条件\n  +显示查询页面(): void\n  +接收查询条件(筛选条件: 房源筛选条件): void\n  +显示房源列表(房源列表: List~房源~): void\n}\n\nclass 房源详情界面 {\n  &lt;&lt;boundary&gt;&gt;\n  +当前房源编号: Long\n  +显示房源详情(房源: 房源): void\n  +显示位置与周边配套(配套信息: 位置与周边配套信息): void\n}\n\n\nclass 统计分析控制类 {\n  &lt;&lt;control&gt;&gt;\n  +获取首页统计结果(): 统计结果\n  +获取省份统计结果(省份名称: String): 统计结果\n  +获取城市统计结果(城市名称: String): 统计结果\n  +获取地区统计结果(地区名称: String): 统计结果\n}\n\nclass 房源查询控制类 {\n  &lt;&lt;control&gt;&gt;\n  +查询房源(筛选条件: 房源筛选条件): List~房源~\n  +查看房源详情(房源编号: Long): 房源\n  +查看位置与周边配套(房源编号: Long): 位置与周边配套信息\n}\n\n\nclass 统计分析服务接口 {\n  &lt;&lt;interface&gt;&gt;\n  +统计房源数量(): Integer\n  +统计平均价格(): Double\n  +统计区域分布(): Map~String,Integer~\n  +统计价格趋势(): List~统计结果~\n  +形成统计结果(): 统计结果\n}\n\nclass 房源查询服务接口 {\n  &lt;&lt;interface&gt;&gt;\n  +根据条件筛选房源(筛选条件: 房源筛选条件): List~房源~\n  +获取房源详情(房源编号: Long): 房源\n  +获取房源配套信息(房源编号: Long): 位置与周边配套信息\n}\n\n\nclass 统计分析服务类 {\n  &lt;&lt;service&gt;&gt;\n  +统计房源数量(): Integer\n  +统计平均价格(): Double\n  +统计区域分布(): Map~String,Integer~\n  +统计价格趋势(): List~统计结果~\n  +形成统计结果(): 统计结果\n}\n\nclass 房源查询服务类 {\n  &lt;&lt;service&gt;&gt;\n  +根据条件筛选房源(筛选条件: 房源筛选条件): List~房源~\n  +获取房源详情(房源编号: Long): 房源\n  +获取房源配套信息(房源编号: Long): 位置与周边配套信息\n}\n\n\nclass 房源筛选条件 {\n  &lt;&lt;valueObject&gt;&gt;\n  +省份名称: String\n  +城市名称: String\n  +地区名称: String\n  +小区名称: String\n  +最低总价: Double\n  +最高总价: Double\n  +最低面积: Double\n  +最高面积: Double\n  +户型要求: String\n  +装修要求: String\n  +是否有效(): Boolean\n}\n\n\nclass 省份 {\n  &lt;&lt;entity&gt;&gt;\n  +省份编号: Long\n  +省份名称: String\n  +城市数量: Integer\n  +房源数量: Integer\n  +平均价格: Double\n  +统计省份房源(): 统计结果\n}\n\nclass 城市 {\n  &lt;&lt;entity&gt;&gt;\n  +城市编号: Long\n  +城市名称: String\n  +所属省份: String\n  +房源数量: Integer\n  +平均价格: Double\n  +统计城市房源(): 统计结果\n}\n\nclass 地区 {\n  &lt;&lt;entity&gt;&gt;\n  +地区编号: Long\n  +地区名称: String\n  +所属城市: String\n  +房源数量: Integer\n  +价格水平: Double\n  +统计地区房源(): 统计结果\n}\n\nclass 小区 {\n  &lt;&lt;entity&gt;&gt;\n  +小区编号: Long\n  +小区名称: String\n  +所属地区: String\n  +房源数量: Integer\n  +归集房源(): List~房源~\n}\n\nclass 房源 {\n  &lt;&lt;entity&gt;&gt;\n  +房源编号: Long\n  +房源名称: String\n  +省份名称: String\n  +城市名称: String\n  +地区名称: String\n  +小区名称: String\n  +总价: Double\n  +单价: Double\n  +面积: Double\n  +户型: String\n  +楼层: String\n  +朝向: String\n  +装修: String\n  +经度: Double\n  +纬度: Double\n  +房源状态: 房源状态\n  +展示房源信息(): String\n}\n\nclass 位置与周边配套信息 {\n  &lt;&lt;entity&gt;&gt;\n  +房源编号: Long\n  +地图位置: String\n  +交通配套: String\n  +教育配套: String\n  +医疗配套: String\n  +商业配套: String\n  +展示详细位置(): String\n  +展示周边配套(): String\n}\n\nclass 房源状态 {\n  &lt;&lt;enumeration&gt;&gt;\n  可展示\n  待完善\n  异常\n  已停用\n}\n\nclass 统计结果 {\n  &lt;&lt;entity&gt;&gt;\n  +统计编号: Long\n  +统计对象: String\n  +统计类型: String\n  +统计数值: Double\n  +生成时间: DateTime\n  +生成统计说明(): String\n}\n\n\n普通用户 -- 首页展示界面 : 关联\n普通用户 -- 房源查询界面 : 关联\n普通用户 -- 房源详情界面 : 关联\n\n首页展示界面 ..&gt; 统计分析控制类 : 依赖\n房源查询界面 ..&gt; 房源查询控制类 : 依赖\n房源详情界面 ..&gt; 房源查询控制类 : 依赖\n\n统计分析控制类 ..&gt; 统计分析服务接口 : 依赖\n房源查询控制类 ..&gt; 房源查询服务接口 : 依赖\n\n统计分析服务接口 &lt;|.. 统计分析服务类 : 实现\n房源查询服务接口 &lt;|.. 房源查询服务类 : 实现\n\n统计分析服务类 -- 房源 : 关联\n统计分析服务类 -- 统计结果 : 关联\n\n房源查询服务类 -- 房源筛选条件 : 关联\n房源查询服务类 -- 房源 : 关联\n房源查询服务类 -- 位置与周边配套信息 : 关联\n\n省份 \&quot;1\&quot; o-- \&quot;0..*\&quot; 城市 : 聚合\n城市 \&quot;1\&quot; o-- \&quot;0..*\&quot; 地区 : 聚合\n地区 \&quot;1\&quot; o-- \&quot;0..*\&quot; 小区 : 聚合\n小区 \&quot;1\&quot; o-- \&quot;0..*\&quot; 房源 : 聚合\n\n房源 \&quot;1\&quot; *-- \&quot;0..1\&quot; 位置与周边配套信息 : 组合\n房源 -- 房源状态 : 关联\n\n首页展示界面 -- 统计结果 : 关联\n省份 -- 统计结果 : 关联\n城市 -- 统计结果 : 关联\n地区 -- 统计结果 : 关联&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="rvZjHZs7JUC4JIlDZKwR-4965">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=1;groupPadding=20;" vertex="1">
            <mxGeometry height="38232" width="5206" as="geometry" />
          </mxCell>
        </UserObject>
