  <diagram id="fl9xfNhWkkD3o6kS0MvC" name="第 2 页">
    <mxGraphModel dx="5150" dy="2810" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\ndirection LR\n\n%% =========================\n%% 枚举类型\n%% =========================\n\nclass 用户状态 {\n  &lt;&lt;enumeration&gt;&gt;\n  启用\n  禁用\n  锁定\n}\n\nclass 请求状态 {\n  &lt;&lt;enumeration&gt;&gt;\n  未提交\n  已提交\n  预测成功\n  预测失败\n}\n\nclass 资料状态 {\n  &lt;&lt;enumeration&gt;&gt;\n  原始\n  待补充\n  待整理\n  异常\n  已更新\n  已标准化\n}\n\nclass 异常类型 {\n  &lt;&lt;enumeration&gt;&gt;\n  字段缺失\n  格式不规范\n  数值异常\n  重复数据\n  无效数据\n}\n\n%% =========================\n%% 用户类\n%% =========================\n\nclass 用户 {\n  &lt;&lt;abstract&gt;&gt;\n  #Long 用户编号\n  #String 用户身份\n  #用户状态 使用状态\n  #DateTime 创建时间\n  #DateTime 最近登录时间\n  +进入系统() Boolean\n  +退出系统() void\n  +获取用户身份() String\n  +判断用户是否可用() Boolean\n}\n\nclass 普通用户 {\n  -String 找房需求\n  -String 预测需求\n  +查询房源(筛选条件 condition) List~房源~\n  +提交预测请求(预测请求 request) 预测结果\n}\n\nclass 数据维护人员 {\n  -String 维护范围\n  -String 维护任务\n  +确定维护范围(String range) void\n  +维护房源资料(房源维护资料 material) Boolean\n  +核查房源资料(房源维护资料 material) 核查结果\n}\n\nclass 系统管理员 {\n  -String 管理范围\n  -String 异常处理职责\n  +查看系统状态() 系统状态\n  +处理异常信息(维护记录 record) Boolean\n}\n\n用户 &lt;|-- 普通用户\n用户 &lt;|-- 数据维护人员\n用户 &lt;|-- 系统管理员\n\n用户 ..&gt; 用户状态 : 使用状态类型\n\n%% =========================\n%% 边界类\n%% =========================\n\nclass 房源查询界面 {\n  &lt;&lt;boundary&gt;&gt;\n  -Integer 当前页码\n  -Integer 每页数量\n  -筛选条件 当前筛选条件\n  +显示房源概况() void\n  +显示筛选条件入口() void\n  +接收查询条件() 筛选条件\n  +显示房源列表(List~房源~ houses) void\n  +显示房源详情(房源 house) void\n  +显示位置与配套(详细位置和周边配套 info) void\n  +显示空结果提示() void\n}\n\nclass 房价预测界面 {\n  &lt;&lt;boundary&gt;&gt;\n  -Map~String,Object~ 表单数据\n  -预测请求 当前预测请求\n  +显示预测表单() void\n  +接收房源特征() 预测请求\n  +显示校验错误(String message) void\n  +显示预测结果(预测结果 result) void\n  +返回条件填写区() void\n}\n\nclass 房源维护界面 {\n  &lt;&lt;boundary&gt;&gt;\n  -String 当前维护范围\n  -资料状态 当前资料状态\n  +显示维护页面() void\n  +接收维护范围() String\n  +显示待维护资料(List~房源维护资料~ materials) void\n  +显示核查结果(核查结果 result) void\n  +提交补充资料(房源维护资料 material) Boolean\n  +提交整理结果(房源维护资料 material) Boolean\n  +提交异常处理(异常资料 abnormal) Boolean\n}\n\nclass 系统管理界面 {\n  &lt;&lt;boundary&gt;&gt;\n  -系统状态 当前系统状态\n  +显示系统状态(系统状态 status) void\n  +显示异常信息(List~String~ messages) void\n  +提交异常处理结果(维护记录 record) Boolean\n}\n\n房源维护界面 ..&gt; 资料状态 : 显示资料状态\n\n%% =========================\n%% 控制类\n%% =========================\n\nclass 房源查询控制器 {\n  &lt;&lt;control&gt;&gt;\n  +查询房源(筛选条件 condition) List~房源~\n  +查看房源详情(Long houseId) 房源\n  +查看位置与配套(Long houseId) 详细位置和周边配套\n  -校验筛选条件(筛选条件 condition) Boolean\n  -组织房源列表(List~房源~ houses) List~房源~\n}\n\nclass 房价预测控制器 {\n  &lt;&lt;control&gt;&gt;\n  +提交预测请求(预测请求 request) 预测结果\n  +调整预测条件(预测请求 request) 预测请求\n  -校验预测信息(预测请求 request) Boolean\n  -生成模型输入(预测请求 request) 模型输入数据\n  -生成结果说明(预测结果 result) String\n  -保存预测记录(预测请求 request, 预测结果 result) void\n}\n\nclass 房源维护控制器 {\n  &lt;&lt;control&gt;&gt;\n  +确定维护范围(String range) List~房源维护资料~\n  +核查房源信息(房源维护资料 material) 核查结果\n  +补充房源资料(房源维护资料 material) 房源维护资料\n  +整理房源资料(房源维护资料 material) 房源维护资料\n  +处理异常资料(异常资料 abnormal) 异常资料\n  +更新房源信息(房源维护资料 material) Boolean\n  -记录维护日志(维护记录 record) void\n}\n\nclass 系统管理控制器 {\n  &lt;&lt;control&gt;&gt;\n  +查看系统状态() 系统状态\n  +处理异常信息(维护记录 record) Boolean\n  -生成异常提示(系统状态 status) List~String~\n}\n\n房源查询界面 ..&gt; 房源查询控制器 : 调用\n房价预测界面 ..&gt; 房价预测控制器 : 调用\n房源维护界面 ..&gt; 房源维护控制器 : 调用\n系统管理界面 ..&gt; 系统管理控制器 : 调用\n\n%% =========================\n%% 房源查询相关实体类\n%% =========================\n\nclass 筛选条件 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 条件编号\n  -String 区域范围\n  -BigDecimal 最低价格\n  -BigDecimal 最高价格\n  -Double 最小面积\n  -Double 最大面积\n  -String 户型要求\n  -String 朝向要求\n  -String 楼层要求\n  -String 装修要求\n  +校验条件() Boolean\n  +调整条件(筛选条件 newCondition) void\n  +生成查询条件() Map~String,Object~\n}\n\nclass 房源 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 房源编号\n  -String 房源名称\n  -BigDecimal 总价\n  -BigDecimal 单价\n  -Double 面积\n  -String 户型\n  -String 楼层\n  -String 朝向\n  -String 装修\n  -String 建筑结构\n  -String 产权性质\n  -Date 挂牌时间\n  -Double 经度\n  -Double 纬度\n  -资料状态 资料状态\n  -DateTime 更新时间\n  +展示基本信息() String\n  +展示详细信息() String\n  +参与价格参考() Boolean\n  +更新房源信息(Map~String,Object~ data) void\n  +判断资料是否有效() Boolean\n}\n\nclass 详细位置和周边配套 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 配套编号\n  -String 地图位置\n  -String 交通配套\n  -String 教育配套\n  -String 医疗配套\n  -String 商业配套\n  -String 居住便利度\n  +展示详细位置() String\n  +展示周边配套信息() String\n  +辅助居住判断() String\n}\n\nclass 城市 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 城市编号\n  -String 城市名称\n  -Integer 房源数量\n  -BigDecimal 平均价格\n  +汇总房源情况() Map~String,Object~\n}\n\nclass 地区 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 地区编号\n  -String 地区名称\n  -Integer 房源数量\n  -BigDecimal 价格水平\n  +统计地区房源() Map~String,Object~\n}\n\nclass 小区 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 小区编号\n  -String 小区名称\n  -String 所属区域\n  -Integer 房源数量\n  +归集房源() List~房源~\n}\n\n普通用户 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 筛选条件 : 设置\n筛选条件 ..&gt; 房源 : 限定候选房源\n房源 \&quot;1\&quot; --&gt; \&quot;0..1\&quot; 详细位置和周边配套 : 关联\n城市 \&quot;1\&quot; o-- \&quot;0..*\&quot; 地区 : 包含\n地区 \&quot;1\&quot; o-- \&quot;0..*\&quot; 小区 : 包含\n小区 \&quot;1\&quot; o-- \&quot;0..*\&quot; 房源 : 归集\n\n房源 ..&gt; 资料状态 : 使用资料状态\n\n%% =========================\n%% 房价预测相关实体类\n%% =========================\n\nclass 预测请求 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 请求编号\n  -Long 用户编号\n  -Map~String,Object~ 房源特征\n  -请求状态 请求状态\n  -String 预测目的\n  -DateTime 提交时间\n  +检查信息完整性() Boolean\n  +检查信息合理性() Boolean\n  +形成评估依据() 模型输入数据\n}\n\nclass 模型输入数据 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 输入编号\n  -List~Double~ 数值特征向量\n  -List~Integer~ 类别特征向量\n  -List~Double~ 标准化结果\n  +编码类别特征() List~Integer~\n  +标准化数值特征() List~Double~\n  +生成输入矩阵() List~Double~\n}\n\nclass 预测结果 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 结果编号\n  -Long 请求编号\n  -BigDecimal 参考价格\n  -String 结果说明\n  -String 反馈状态\n  -DateTime 生成时间\n  +反馈参考价格() BigDecimal\n  +说明预测结果() String\n}\n\n普通用户 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 预测请求 : 提交\n预测请求 \&quot;1\&quot; *-- \&quot;1\&quot; 模型输入数据 : 形成\n预测请求 \&quot;1\&quot; --&gt; \&quot;0..1\&quot; 预测结果 : 得到\n预测请求 ..&gt; 房源 : 依赖房源特征\n预测结果 ..&gt; 房源 : 参考房源价格\n\n预测请求 ..&gt; 请求状态 : 使用请求状态\n\n%% =========================\n%% 房源维护相关实体类\n%% =========================\n\nclass 房源维护资料 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 资料编号\n  -String 资料来源\n  -资料状态 资料状态\n  -String 完整性情况\n  -String 规范性情况\n  -DateTime 维护时间\n  +接受核查() 核查结果\n  +接受整理() 房源维护资料\n  +形成标准房源() 房源\n}\n\nclass 核查结果 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 结果编号\n  -Boolean 是否缺失\n  -Boolean 是否不规范\n  -Boolean 是否异常\n  -String 核查说明\n  +是否通过() Boolean\n  +生成处理建议() String\n}\n\nclass 异常资料 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 异常编号\n  -String 异常原因\n  -String 异常状态\n  -异常类型 异常类型\n  -String 处理结果\n  +标记异常(异常类型 type) void\n  +确认异常() Boolean\n  +处理异常(String method) Boolean\n}\n\nclass 维护记录 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 记录编号\n  -String 维护事项\n  -String 处理结果\n  -DateTime 记录时间\n  -Long 维护人员编号\n  +记录维护过程() void\n  +反馈处理结果() String\n}\n\n数据维护人员 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 房源维护资料 : 维护\n数据维护人员 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 维护记录 : 记录\n房源维护资料 \&quot;1\&quot; --&gt; \&quot;0..1\&quot; 房源 : 形成标准房源\n房源维护资料 \&quot;1\&quot; *-- \&quot;0..*\&quot; 异常资料 : 包含\n房源维护资料 \&quot;1\&quot; --&gt; \&quot;1\&quot; 核查结果 : 生成\n维护记录 \&quot;1\&quot; --&gt; \&quot;1\&quot; 房源维护资料 : 记录维护对象\n维护记录 \&quot;0..*\&quot; --&gt; \&quot;0..1\&quot; 异常资料 : 记录异常处理\n\n房源维护资料 ..&gt; 资料状态 : 使用资料状态\n异常资料 ..&gt; 异常类型 : 使用异常类型\n\n%% =========================\n%% 系统管理相关实体类\n%% =========================\n\nclass 系统状态 {\n  &lt;&lt;entity&gt;&gt;\n  -Long 状态编号\n  -String 运行情况\n  -String 异常提示\n  -Boolean 可用状态\n  -DateTime 更新时间\n  +反映运行情况() String\n  +提示异常信息() List~String~\n}\n\n系统管理员 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 系统状态 : 查看\n系统管理员 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 维护记录 : 处理异常\n\n%% =========================\n%% 接口与实现类\n%% =========================\n\nclass 房源数据访问接口 {\n  &lt;&lt;interface&gt;&gt;\n  +findByCondition(筛选条件 condition) List~房源~\n  +findById(Long houseId) 房源\n  +save(房源 house) Boolean\n  +update(房源 house) Boolean\n  +findMaintenanceMaterials(String range) List~房源维护资料~\n}\n\nclass 房源数据访问实现 {\n  &lt;&lt;repository&gt;&gt;\n  -String 数据源\n  +findByCondition(筛选条件 condition) List~房源~\n  +findById(Long houseId) 房源\n  +save(房源 house) Boolean\n  +update(房源 house) Boolean\n  +findMaintenanceMaterials(String range) List~房源维护资料~\n}\n\nclass 地图服务接口 {\n  &lt;&lt;interface&gt;&gt;\n  +getLocation(房源 house) 详细位置和周边配套\n  +searchNearby(Double lng, Double lat, Integer radius) 详细位置和周边配套\n}\n\nclass 百度地图服务实现 {\n  &lt;&lt;service&gt;&gt;\n  -String 百度地图AK\n  +getLocation(房源 house) 详细位置和周边配套\n  +searchNearby(Double lng, Double lat, Integer radius) 详细位置和周边配套\n}\n\nclass 预测模型服务接口 {\n  &lt;&lt;interface&gt;&gt;\n  +loadModel(String modelPath) Boolean\n  +transform(预测请求 request) 模型输入数据\n  +predict(模型输入数据 input) 预测结果\n}\n\nclass 房价预测模型服务实现 {\n  &lt;&lt;service&gt;&gt;\n  -String 模型路径\n  -String 特征规则路径\n  +loadModel(String modelPath) Boolean\n  +transform(预测请求 request) 模型输入数据\n  +predict(模型输入数据 input) 预测结果\n}\n\nclass 系统状态服务接口 {\n  &lt;&lt;interface&gt;&gt;\n  +getCurrentStatus() 系统状态\n  +getExceptionMessages() List~String~\n}\n\nclass 系统状态服务实现 {\n  &lt;&lt;service&gt;&gt;\n  +getCurrentStatus() 系统状态\n  +getExceptionMessages() List~String~\n}\n\n房源数据访问接口 &lt;|.. 房源数据访问实现 : 实现\n地图服务接口 &lt;|.. 百度地图服务实现 : 实现\n预测模型服务接口 &lt;|.. 房价预测模型服务实现 : 实现\n系统状态服务接口 &lt;|.. 系统状态服务实现 : 实现\n\n%% =========================\n%% 控制类与接口依赖\n%% =========================\n\n房源查询控制器 ..&gt; 房源数据访问接口 : 查询房源\n房源查询控制器 ..&gt; 地图服务接口 : 获取位置配套\n\n房价预测控制器 ..&gt; 预测模型服务接口 : 调用预测模型\n房价预测控制器 ..&gt; 房源数据访问接口 : 读取参考房源\n\n房源维护控制器 ..&gt; 房源数据访问接口 : 维护房源资料\n\n系统管理控制器 ..&gt; 系统状态服务接口 : 获取系统状态&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="lyqxtfof2jnrY6uWBckb-389">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
