        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\ndirection LR\n\nclass 用户 {\n  &lt;&lt;actor&gt;&gt;\n  +用户编号: Long\n  +用户名: String\n  +用户角色: String\n  +进入系统(): void\n  +退出系统(): void\n}\n\nclass 普通用户 {\n  &lt;&lt;actor&gt;&gt;\n  +找房需求: String\n  +预测需求: String\n  +查询房源(): void\n  +提交预测请求(): void\n}\n\nclass 数据维护人员 {\n  &lt;&lt;actor&gt;&gt;\n  +维护范围: String\n  +维护任务状态: String\n  +核查房源资料(): void\n  +更新房源资料(): void\n}\n\nclass 系统管理员 {\n  &lt;&lt;actor&gt;&gt;\n  +管理范围: String\n  +异常处理状态: String\n  +查看系统状态(): void\n  +处理异常信息(): void\n}\n\n用户 &lt;|-- 普通用户 : 泛化\n用户 &lt;|-- 数据维护人员 : 泛化\n用户 &lt;|-- 系统管理员 : 泛化\n\n\nclass 查询房源模块 {\n  &lt;&lt;module&gt;&gt;\n  +查看房源概况(): 统计结果\n  +设置查询条件(): 房源筛选条件\n  +查询房源(筛选条件: 房源筛选条件): List~房源~\n  +查看房源详情(房源编号: Long): 房源\n  +查看位置与周边配套(房源编号: Long): 位置与周边配套信息\n}\n\nclass 房价预测模块 {\n  &lt;&lt;module&gt;&gt;\n  +填写房源特征(): 房源预测条件\n  +调整预测条件(预测条件: 房源预测条件): 房源预测条件\n  +提交预测请求(预测条件: 房源预测条件): 预测结果\n  +查看预测结果(结果编号: Long): 预测结果\n}\n\nclass 房源资料维护模块 {\n  &lt;&lt;module&gt;&gt;\n  +确定维护范围(): 房源维护范围\n  +核查房源资料(资料编号: Long): 房源资料核查结果\n  +更新房源信息(更新记录: 房源资料更新记录): 房源\n  +处理异常资料(异常资料: 异常资料): Boolean\n}\n\nclass 系统基础管理模块 {\n  &lt;&lt;module&gt;&gt;\n  +查看系统状态(): 系统状态\n  +维护基础业务配置(配置项: 基础业务配置): Boolean\n  +管理用户与权限(权限信息: 用户与权限信息): Boolean\n  +处理异常信息(异常信息: 异常信息): Boolean\n}\n\n\nclass 房源 {\n  &lt;&lt;entity&gt;&gt;\n  +房源编号: Long\n  +房源名称: String\n  +省份名称: String\n  +城市名称: String\n  +地区名称: String\n  +小区名称: String\n  +总价: Double\n  +单价: Double\n  +价格概况: String\n  +面积: Double\n  +户型: String\n  +楼层: String\n  +朝向: String\n  +装修: String\n  +位置概况: String\n  +周边配套概况: String\n  +房源状态: String\n  +展示房源信息(): String\n}\n\nclass 位置与周边配套信息 {\n  &lt;&lt;entity&gt;&gt;\n  +房源编号: Long\n  +地图位置: String\n  +交通配套: String\n  +教育配套: String\n  +医疗配套: String\n  +商业配套: String\n  +展示详细位置(): String\n  +展示周边配套(): String\n}\n\nclass 统计结果 {\n  &lt;&lt;entity&gt;&gt;\n  +统计编号: Long\n  +统计对象: String\n  +统计类型: String\n  +统计数值: Double\n  +生成时间: DateTime\n  +生成统计说明(): String\n}\n\nclass 房源筛选条件 {\n  &lt;&lt;valueObject&gt;&gt;\n  +省份名称: String\n  +城市名称: String\n  +地区名称: String\n  +小区名称: String\n  +最低总价: Double\n  +最高总价: Double\n  +最低面积: Double\n  +最高面积: Double\n  +户型要求: String\n  +装修要求: String\n  +是否有效(): Boolean\n}\n\nclass 房源预测条件 {\n  &lt;&lt;valueObject&gt;&gt;\n  +省份名称: String\n  +城市名称: String\n  +地区名称: String\n  +面积: Double\n  +户型: String\n  +楼层: String\n  +朝向: String\n  +装修: String\n  +建筑类型: String\n  +是否有效(): Boolean\n}\n\nclass 预测请求 {\n  &lt;&lt;entity&gt;&gt;\n  +请求编号: Long\n  +请求状态: String\n  +提交时间: DateTime\n  +检查信息完整性(): Boolean\n  +检查信息合理性(): Boolean\n}\n\nclass 预测结果 {\n  &lt;&lt;entity&gt;&gt;\n  +结果编号: Long\n  +参考价格: Double\n  +价格区间: String\n  +结果说明: String\n  +反馈状态: String\n  +生成时间: DateTime\n}\n\nclass 价格模型 {\n  &lt;&lt;entity&gt;&gt;\n  +模型编号: Long\n  +模型名称: String\n  +模型版本: String\n  +模型状态: String\n  +输出预测价格(预测请求: 预测请求): Double\n}\n\nclass 模型报告 {\n  &lt;&lt;entity&gt;&gt;\n  +报告编号: Long\n  +模型名称: String\n  +样本数量: Integer\n  +平均绝对误差: Double\n  +均方根误差: Double\n  +决定系数: Double\n}\n\nclass 房源维护范围 {\n  &lt;&lt;valueObject&gt;&gt;\n  +省份名称: String\n  +城市名称: String\n  +地区名称: String\n  +小区名称: String\n  +资料状态: String\n  +是否有效(): Boolean\n}\n\nclass 房源维护资料 {\n  &lt;&lt;entity&gt;&gt;\n  +资料编号: Long\n  +资料来源: String\n  +房源名称: String\n  +资料状态: String\n  +完整性情况: String\n  +规范性情况: String\n  +异常说明: String\n  +更新时间: DateTime\n  +形成标准房源(): 房源\n}\n\nclass 房源资料核查结果 {\n  &lt;&lt;entity&gt;&gt;\n  +核查编号: Long\n  +资料编号: Long\n  +是否缺失: Boolean\n  +是否不规范: Boolean\n  +是否异常: Boolean\n  +是否重复: Boolean\n  +核查说明: String\n}\n\nclass 房源资料更新记录 {\n  &lt;&lt;entity&gt;&gt;\n  +更新编号: Long\n  +资料编号: Long\n  +更新前内容: String\n  +更新后内容: String\n  +维护人员: String\n  +更新时间: DateTime\n  +更新结果: String\n}\n\nclass 异常资料 {\n  &lt;&lt;entity&gt;&gt;\n  +异常编号: Long\n  +资料编号: Long\n  +异常原因: String\n  +异常状态: String\n  +处理结果: String\n}\n\nclass 系统状态 {\n  &lt;&lt;entity&gt;&gt;\n  +状态编号: Long\n  +运行情况: String\n  +异常提示: String\n  +可用状态: Boolean\n  +检查时间: DateTime\n}\n\nclass 基础业务配置 {\n  &lt;&lt;entity&gt;&gt;\n  +配置编号: Long\n  +配置名称: String\n  +配置值: String\n  +配置说明: String\n  +配置状态: String\n}\n\nclass 用户与权限信息 {\n  &lt;&lt;entity&gt;&gt;\n  +用户编号: Long\n  +用户账号: String\n  +用户姓名: String\n  +角色名称: String\n  +权限范围: String\n  +用户状态: String\n}\n\nclass 异常信息 {\n  &lt;&lt;entity&gt;&gt;\n  +异常编号: Long\n  +异常来源: String\n  +异常原因: String\n  +异常级别: String\n  +处理状态: String\n  +处理说明: String\n}\n\nclass 管理操作记录 {\n  &lt;&lt;entity&gt;&gt;\n  +记录编号: Long\n  +操作类型: String\n  +操作对象: String\n  +操作人员: String\n  +操作时间: DateTime\n  +操作结果: String\n}\n\n\n普通用户 -- 查询房源模块 : 关联\n普通用户 -- 房价预测模块 : 关联\n数据维护人员 -- 房源资料维护模块 : 关联\n系统管理员 -- 系统基础管理模块 : 关联\n\n查询房源模块 ..&gt; 房源筛选条件 : 依赖\n查询房源模块 ..&gt; 房源 : 依赖\n查询房源模块 ..&gt; 统计结果 : 依赖\n查询房源模块 ..&gt; 位置与周边配套信息 : 依赖\n\n房价预测模块 ..&gt; 房源预测条件 : 依赖\n房价预测模块 ..&gt; 预测请求 : 依赖\n房价预测模块 ..&gt; 预测结果 : 依赖\n房价预测模块 ..&gt; 价格模型 : 依赖\n房价预测模块 ..&gt; 模型报告 : 依赖\n\n房源资料维护模块 ..&gt; 房源维护范围 : 依赖\n房源资料维护模块 ..&gt; 房源维护资料 : 依赖\n房源资料维护模块 ..&gt; 房源资料核查结果 : 依赖\n房源资料维护模块 ..&gt; 房源资料更新记录 : 依赖\n房源资料维护模块 ..&gt; 异常资料 : 依赖\n房源资料维护模块 ..&gt; 房源 : 依赖\n\n系统基础管理模块 ..&gt; 系统状态 : 依赖\n系统基础管理模块 ..&gt; 基础业务配置 : 依赖\n系统基础管理模块 ..&gt; 用户与权限信息 : 依赖\n系统基础管理模块 ..&gt; 异常信息 : 依赖\n系统基础管理模块 ..&gt; 管理操作记录 : 依赖\n\n房源 \&quot;1\&quot; *-- \&quot;0..1\&quot; 位置与周边配套信息 : 组合\n\n预测请求 \&quot;1\&quot; *-- \&quot;1\&quot; 房源预测条件 : 组合\n预测请求 \&quot;1\&quot; *-- \&quot;0..1\&quot; 预测结果 : 组合\n\n价格模型 -- 模型报告 : 关联\n\n房源维护资料 \&quot;1\&quot; *-- \&quot;0..*\&quot; 房源资料核查结果 : 组合\n房源维护资料 \&quot;1\&quot; *-- \&quot;0..*\&quot; 房源资料更新记录 : 组合\n房源维护资料 \&quot;1\&quot; *-- \&quot;0..*\&quot; 异常资料 : 组合\n\n查询房源模块 ..&gt; 基础业务配置 : 依赖\n房价预测模块 ..&gt; 基础业务配置 : 依赖\n房源资料维护模块 ..&gt; 基础业务配置 : 依赖\n\n系统状态 -- 异常信息 : 关联\n系统管理员 -- 管理操作记录 : 关联&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="rvZjHZs7JUC4JIlDZKwR-5873">
