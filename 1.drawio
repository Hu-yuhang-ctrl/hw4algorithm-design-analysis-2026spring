        <mxCell id="rvZjHZs7JUC4JIlDZKwR-4181" parent="rvZjHZs7JUC4JIlDZKwR-4174" style="text;fontSize=16;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontColor=light-dark(#333333,#cccccc);" value="+统计区域房源数量(): int" vertex="1">
