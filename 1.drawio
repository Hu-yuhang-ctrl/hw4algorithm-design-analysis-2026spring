        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;%%{init: {\&quot;theme\&quot;:\&quot;base\&quot;,\&quot;themeVariables\&quot;:{\&quot;background\&quot;:\&quot;#ffffff\&quot;,\&quot;primaryColor\&quot;:\&quot;#ffffff\&quot;,\&quot;primaryTextColor\&quot;:\&quot;#000000\&quot;,\&quot;primaryBorderColor\&quot;:\&quot;#000000\&quot;,\&quot;lineColor\&quot;:\&quot;#000000\&quot;,\&quot;fontFamily\&quot;:\&quot;Microsoft YaHei\&quot;}}}%%\nflowchart TB\n\n    EXT[\&quot;外部房源信息来源\&quot;]\n    CLEAN[\&quot;数据采集与清洗\&quot;]\n\n    L1[\&quot;1. 页面展示层&lt;br/&gt;&lt;br/&gt;普通用户端：概况展示、房源查询、房源详情、位置配套、房价预测&lt;br/&gt;数据维护端：资料维护、质量检查、异常资料处理&lt;br/&gt;系统管理端：状态查看、用户权限、基础配置、异常处理&lt;br/&gt;&lt;br/&gt;负责页面展示、用户输入与结果反馈\&quot;]\n\n    L2[\&quot;2. 服务接口层&lt;br/&gt;&lt;br/&gt;查询接口、详情接口、地图配套接口、预测接口、维护接口、系统管理接口&lt;br/&gt;&lt;br/&gt;基于 Django 路由 / 视图，负责接收请求并返回结构化数据\&quot;]\n\n    L3[\&quot;3. 业务处理层&lt;br/&gt;&lt;br/&gt;查询处理、详情处理、地图配套处理、房价预测处理&lt;br/&gt;资料维护处理、用户权限处理、基础配置处理、日志与异常处理&lt;br/&gt;&lt;br/&gt;Django 控制与服务逻辑 + Python 数据处理与机器学习预测\&quot;]\n\n    L4[\&quot;4. 数据支撑层&lt;br/&gt;&lt;br/&gt;标准房源数据、区域与配套信息、预测记录、维护记录&lt;br/&gt;用户与权限信息、基础配置数据、系统日志、预测模型&lt;br/&gt;&lt;br/&gt;负责数据存储、记录保存与模型支撑\&quot;]\n\n    MAP[\&quot;地图服务\&quot;]\n\n    EXT --&gt; CLEAN\n    CLEAN --&gt; L4\n\n    L1 &lt;--&gt;|页面请求 / 结果反馈| L2\n    L2 &lt;--&gt;|业务调用 / 结果返回| L3\n    L3 &lt;--&gt;|数据访问、模型调用 / 结果返回| L4\n\n    L3 &lt;--&gt;|地图位置与周边配套请求 / 返回| MAP\n\n    classDef default fill:#ffffff,stroke:#000000,color:#000000,stroke-width:1.2px;\n    classDef external fill:#ffffff,stroke:#000000,color:#000000,stroke-width:1.2px;\n\n    class L1,L2,L3,L4,EXT,CLEAN,MAP default;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="Tu3zdjrg4u6U8YNrI88j-1">
