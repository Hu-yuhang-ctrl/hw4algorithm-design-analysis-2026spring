        <mxCell id="9OTB4NZnKCTOTTPslyz2-6" parent="9OTB4NZnKCTOTTPslyz2-3" style="text;fontSize=16;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;" value="锁定" vertex="1">
