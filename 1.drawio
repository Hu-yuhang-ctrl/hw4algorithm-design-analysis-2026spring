            <mxGeometry height="40" width="1980" x="1280" y="16360" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    autonumber\n\n    actor Admin as 系统管理员\n\n    participant Page as 系统基础管理界面&lt;br/&gt;«boundary»\n    participant Ctrl as 系统基础管理控制类&lt;br/&gt;«control»\n\n    participant UserApi as 用户权限管理接口&lt;br/&gt;«interface»\n    participant UserSvc as 用户权限管理服务类&lt;br/&gt;«service»\n\n    participant ConfigApi as 基础业务配置接口&lt;br/&gt;«interface»\n    participant ConfigSvc as 基础业务配置服务类&lt;br/&gt;«service»\n\n    participant UserInfo as 用户与权限信息&lt;br/&gt;«entity»\n    participant Config as 基础业务配置&lt;br/&gt;«entity»\n    participant Log as 管理操作记录&lt;br/&gt;«entity»\n\n    Admin -&gt;&gt; Page: 进入用户与权限管理页面()\n    activate Page\n\n    Page -&gt;&gt; Ctrl: 加载用户列表、角色列表和权限配置()\n    activate Ctrl\n\n    Ctrl -&gt;&gt; UserApi: 获取用户列表()\n    activate UserApi\n    UserApi -&gt;&gt; UserSvc: 查询用户与权限信息()\n    activate UserSvc\n    UserSvc -&gt;&gt; UserInfo: 读取用户账号、角色、状态和权限范围()\n    activate UserInfo\n    UserInfo --&gt;&gt; UserSvc: 返回用户与权限信息列表\n    deactivate UserInfo\n    UserSvc --&gt;&gt; UserApi: 返回用户列表\n    deactivate UserSvc\n    UserApi --&gt;&gt; Ctrl: 返回用户列表\n    deactivate UserApi\n\n    Ctrl -&gt;&gt; ConfigApi: 获取角色列表和权限配置()\n    activate ConfigApi\n    ConfigApi -&gt;&gt; ConfigSvc: 查询基础业务配置(角色, 权限)\n    activate ConfigSvc\n    ConfigSvc -&gt;&gt; Config: 读取角色配置和权限配置()\n    activate Config\n    Config --&gt;&gt; ConfigSvc: 返回角色与权限配置\n    deactivate Config\n    ConfigSvc --&gt;&gt; ConfigApi: 返回角色与权限配置\n    deactivate ConfigSvc\n    ConfigApi --&gt;&gt; Ctrl: 返回角色列表和权限配置\n    deactivate ConfigApi\n\n    Ctrl --&gt;&gt; Page: 返回用户列表、角色列表和权限配置\n    deactivate Ctrl\n    Page --&gt;&gt; Admin: 展示用户与权限管理页面\n\n    Admin -&gt;&gt; Page: 选择用户管理操作()\n\n    alt 新增用户\n        Admin -&gt;&gt; Page: 填写用户账号、姓名、角色等信息()\n        Page -&gt;&gt; Ctrl: 新增用户(用户与权限信息)\n        activate Ctrl\n\n        Ctrl -&gt;&gt; UserApi: 校验用户信息(用户与权限信息)\n        activate UserApi\n        UserApi -&gt;&gt; UserSvc: 检查账号是否为空和是否已存在()\n        activate UserSvc\n        UserSvc -&gt;&gt; UserInfo: 校验用户账号和基础信息()\n        activate UserInfo\n        UserInfo --&gt;&gt; UserSvc: 返回校验结果\n        deactivate UserInfo\n        UserSvc --&gt;&gt; UserApi: 返回用户信息校验结果\n        deactivate UserSvc\n        UserApi --&gt;&gt; Ctrl: 返回校验结果\n        deactivate UserApi\n\n        alt 用户信息无效\n            Ctrl --&gt;&gt; Page: 返回用户信息不完整或账号重复\n            Page --&gt;&gt; Admin: 提示用户信息不完整或账号重复\n\n        else 用户信息有效\n            Ctrl -&gt;&gt; UserApi: 创建用户并分配角色权限()\n            activate UserApi\n            UserApi -&gt;&gt; UserSvc: 新增用户并设置初始权限()\n            activate UserSvc\n            UserSvc -&gt;&gt; UserInfo: 创建用户账号并分配角色权限()\n            activate UserInfo\n            UserInfo --&gt;&gt; UserSvc: 返回新增用户信息\n            deactivate UserInfo\n            UserSvc -&gt;&gt; Log: 生成管理操作记录(新增用户)\n            activate Log\n            Log --&gt;&gt; UserSvc: 返回操作日志\n            deactivate Log\n            UserSvc --&gt;&gt; UserApi: 返回新增用户结果\n            deactivate UserSvc\n            UserApi --&gt;&gt; Ctrl: 返回新增用户结果\n            deactivate UserApi\n            Ctrl --&gt;&gt; Page: 返回新增成功\n            Page --&gt;&gt; Admin: 提示操作成功\n        end\n\n        deactivate Ctrl\n\n    else 修改用户角色或权限\n        Admin -&gt;&gt; Page: 选择目标用户并调整角色权限()\n        Page -&gt;&gt; Ctrl: 修改用户权限(用户编号, 角色权限配置)\n        activate Ctrl\n\n        Ctrl -&gt;&gt; UserApi: 查询用户当前角色和权限()\n        activate UserApi\n        UserApi -&gt;&gt; UserSvc: 获取用户当前权限信息(用户编号)\n        activate UserSvc\n        UserSvc -&gt;&gt; UserInfo: 读取用户角色和权限范围()\n        activate UserInfo\n        UserInfo --&gt;&gt; UserSvc: 返回当前角色和权限\n        deactivate UserInfo\n        UserSvc --&gt;&gt; UserApi: 返回当前角色和权限\n        deactivate UserSvc\n        UserApi --&gt;&gt; Ctrl: 返回当前角色和权限\n        deactivate UserApi\n\n        Ctrl -&gt;&gt; ConfigApi: 校验权限配置是否合理()\n        activate ConfigApi\n        ConfigApi -&gt;&gt; ConfigSvc: 校验角色与权限配置()\n        activate ConfigSvc\n        ConfigSvc -&gt;&gt; Config: 检查角色权限范围()\n        activate Config\n        Config --&gt;&gt; ConfigSvc: 返回配置校验结果\n        deactivate Config\n        ConfigSvc --&gt;&gt; ConfigApi: 返回权限配置校验结果\n        deactivate ConfigSvc\n        ConfigApi --&gt;&gt; Ctrl: 返回权限配置校验结果\n        deactivate ConfigApi\n\n        alt 权限配置不合理\n            Ctrl --&gt;&gt; Page: 返回权限配置错误\n            Page --&gt;&gt; Admin: 提示权限配置错误\n\n        else 权限配置合理\n            Ctrl -&gt;&gt; UserApi: 保存新的角色和权限配置()\n            activate UserApi\n            UserApi -&gt;&gt; UserSvc: 更新用户角色和权限范围()\n            activate UserSvc\n            UserSvc -&gt;&gt; UserInfo: 修改用户角色和权限信息()\n            activate UserInfo\n            UserInfo --&gt;&gt; UserSvc: 返回更新后的用户权限信息\n            deactivate UserInfo\n            UserSvc -&gt;&gt; Log: 生成管理操作记录(修改权限)\n            activate Log\n            Log --&gt;&gt; UserSvc: 返回操作日志\n            deactivate Log\n            UserSvc --&gt;&gt; UserApi: 返回权限更新结果\n            deactivate UserSvc\n            UserApi --&gt;&gt; Ctrl: 返回权限更新结果\n            deactivate UserApi\n            Ctrl --&gt;&gt; Page: 返回修改成功\n            Page --&gt;&gt; Admin: 提示操作成功\n        end\n\n        deactivate Ctrl\n\n    else 启用或停用用户\n        Admin -&gt;&gt; Page: 选择目标用户并修改启用状态()\n        Page -&gt;&gt; Ctrl: 修改用户启用状态(用户编号, 目标状态)\n        activate Ctrl\n\n        Ctrl -&gt;&gt; UserApi: 检查用户当前状态()\n        activate UserApi\n        UserApi -&gt;&gt; UserSvc: 查询用户状态(用户编号)\n        activate UserSvc\n        UserSvc -&gt;&gt; UserInfo: 读取用户当前状态()\n        activate UserInfo\n        UserInfo --&gt;&gt; UserSvc: 返回用户当前状态\n        deactivate UserInfo\n        UserSvc --&gt;&gt; UserApi: 返回用户当前状态\n        deactivate UserSvc\n        UserApi --&gt;&gt; Ctrl: 返回用户当前状态\n        deactivate UserApi\n\n        Ctrl -&gt;&gt; UserApi: 更新用户启用状态()\n        activate UserApi\n        UserApi -&gt;&gt; UserSvc: 修改用户状态(用户编号, 目标状态)\n        activate UserSvc\n        UserSvc -&gt;&gt; UserInfo: 更新用户状态()\n        activate UserInfo\n        UserInfo --&gt;&gt; UserSvc: 返回状态更新结果\n        deactivate UserInfo\n        UserSvc -&gt;&gt; Log: 生成管理操作记录(启用或停用用户)\n        activate Log\n        Log --&gt;&gt; UserSvc: 返回操作日志\n        deactivate Log\n        UserSvc --&gt;&gt; UserApi: 返回用户状态更新结果\n        deactivate UserSvc\n        UserApi --&gt;&gt; Ctrl: 返回用户状态更新结果\n        deactivate UserApi\n\n        Ctrl --&gt;&gt; Page: 返回状态修改成功\n        Page --&gt;&gt; Admin: 提示操作成功\n\n        deactivate Ctrl\n\n    else 取消管理操作\n        Page --&gt;&gt; Admin: 取消用户管理操作\n    end\n\n    opt 操作成功后刷新页面数据\n        Page -&gt;&gt; Ctrl: 刷新用户列表和权限信息()\n        activate Ctrl\n\n        Ctrl -&gt;&gt; UserApi: 获取最新用户列表()\n        activate UserApi\n        UserApi -&gt;&gt; UserSvc: 查询用户与权限信息()\n        activate UserSvc\n        UserSvc --&gt;&gt; UserApi: 返回最新用户列表\n        deactivate UserSvc\n        UserApi --&gt;&gt; Ctrl: 返回最新用户列表\n        deactivate UserApi\n\n        Ctrl -&gt;&gt; ConfigApi: 获取最新角色和权限配置()\n        activate ConfigApi\n        ConfigApi -&gt;&gt; ConfigSvc: 查询基础业务配置()\n        activate ConfigSvc\n        ConfigSvc --&gt;&gt; ConfigApi: 返回最新配置\n        deactivate ConfigSvc\n        ConfigApi --&gt;&gt; Ctrl: 返回最新角色和权限配置\n        deactivate ConfigApi\n\n        Ctrl --&gt;&gt; Page: 返回最新用户和权限信息\n        deactivate Ctrl\n\n        Page --&gt;&gt; Admin: 刷新用户列表和权限信息\n    end\n\n    deactivate Page&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="ga7TxaUMcuUv2jMxE_gn-1">
