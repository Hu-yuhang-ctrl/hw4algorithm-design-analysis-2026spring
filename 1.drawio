          </mxCell>
        </UserObject>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    autonumber\n\n    actor User as 普通用户\n\n    participant QueryPage as 房源查询界面&lt;br/&gt;«boundary»\n    participant DetailPage as 房源详情界面&lt;br/&gt;«boundary»\n\n    participant BrowseController as 房源查询控制类&lt;br/&gt;«control»\n    participant BrowseInterface as 房源浏览接口&lt;br/&gt;«interface»\n    participant BrowseService as 房源浏览服务类&lt;br/&gt;«service»\n\n    participant FilterCondition as 房源筛选条件&lt;br/&gt;«valueObject»\n    participant House as 房源&lt;br/&gt;«entity»\n    participant LocationInfo as 位置与周边配套信息&lt;br/&gt;«entity»\n\n    Note over User,QueryPage: 进入房源查询界面并加载筛选条件\n\n    User -&gt;&gt; QueryPage: 进入房源查询界面()\n    activate QueryPage\n\n    QueryPage -&gt;&gt; BrowseController: 获取可选筛选条件()\n    activate BrowseController\n\n    BrowseController -&gt;&gt; BrowseInterface: 获取房源筛选条件选项()\n    activate BrowseInterface\n\n    BrowseInterface -&gt;&gt; BrowseService: 获取可选筛选条件()\n    activate BrowseService\n\n    BrowseService --&gt;&gt; BrowseInterface: 返回城市、区域、价格、面积、户型等选项\n    deactivate BrowseService\n\n    BrowseInterface --&gt;&gt; BrowseController: 返回筛选条件选项\n    deactivate BrowseInterface\n\n    BrowseController --&gt;&gt; QueryPage: 返回可选筛选条件\n    deactivate BrowseController\n\n    QueryPage -&gt;&gt; QueryPage: 显示城市、区域、价格、面积、户型、朝向、楼层、装修等筛选项()\n\n    Note over User,FilterCondition: 用户填写并校验筛选条件\n\n    User -&gt;&gt; QueryPage: 填写或修改筛选条件()\n\n    QueryPage -&gt;&gt; FilterCondition: 创建筛选条件对象()\n    activate FilterCondition\n\n    QueryPage -&gt;&gt; FilterCondition: 校验筛选条件()\n    FilterCondition --&gt;&gt; QueryPage: 返回校验结果\n\n    alt 城市或区域未选择\n        QueryPage -&gt;&gt; QueryPage: 提示请选择城市或区域()\n        QueryPage -&gt;&gt; QueryPage: 标记缺失条件()\n        QueryPage --&gt;&gt; User: 返回筛选条件设置区域\n\n    else 价格或面积范围不合法\n        QueryPage -&gt;&gt; QueryPage: 提示价格或面积范围不合法()\n        QueryPage -&gt;&gt; QueryPage: 标记错误输入项()\n        QueryPage --&gt;&gt; User: 返回筛选条件设置区域\n\n    else 筛选条件合法\n        QueryPage -&gt;&gt; FilterCondition: 整理筛选条件()\n        FilterCondition --&gt;&gt; QueryPage: 返回房源查询条件\n    end\n\n    deactivate FilterCondition\n\n    Note over User,House: 提交筛选条件并查询房源\n\n    User -&gt;&gt; QueryPage: 提交筛选条件()\n\n    QueryPage -&gt;&gt; BrowseController: 查询房源(房源筛选条件)\n    activate BrowseController\n\n    BrowseController -&gt;&gt; FilterCondition: 校验筛选条件()\n    activate FilterCondition\n    FilterCondition --&gt;&gt; BrowseController: 返回true\n    deactivate FilterCondition\n\n    BrowseController -&gt;&gt; BrowseInterface: 根据条件筛选房源(房源筛选条件)\n    activate BrowseInterface\n\n    BrowseInterface -&gt;&gt; BrowseService: 根据条件筛选房源(房源筛选条件)\n    activate BrowseService\n\n    BrowseService -&gt;&gt; House: 匹配房源属性(价格, 面积, 户型, 朝向, 楼层, 装修)\n    activate House\n    House --&gt;&gt; BrowseService: 返回符合条件的房源集合\n    deactivate House\n\n    BrowseService --&gt;&gt; BrowseInterface: 返回房源列表\n    deactivate BrowseService\n\n    BrowseInterface --&gt;&gt; BrowseController: 返回房源列表\n    deactivate BrowseInterface\n\n    BrowseController --&gt;&gt; QueryPage: 返回查询结果\n    deactivate BrowseController\n\n    alt 查询结果为空\n        QueryPage -&gt;&gt; QueryPage: 显示无符合条件的房源()\n        QueryPage --&gt;&gt; User: 提示暂无符合条件的房源\n\n        opt 用户继续调整筛选条件\n            User -&gt;&gt; QueryPage: 调整筛选条件()\n            QueryPage -&gt;&gt; QueryPage: 返回筛选条件设置区域()\n        end\n\n    else 查询结果不为空\n        QueryPage -&gt;&gt; QueryPage: 显示筛选后的房源列表()\n        QueryPage --&gt;&gt; User: 展示房源列表\n    end\n\n    Note over User,DetailPage: 查看房源详情\n\n    opt 用户选择某一套房源查看详情\n        User -&gt;&gt; QueryPage: 选择房源(房源编号)\n\n        QueryPage -&gt;&gt; BrowseController: 查看房源详情(房源编号)\n        activate BrowseController\n\n        BrowseController -&gt;&gt; BrowseInterface: 获取房源详情信息(房源编号)\n        activate BrowseInterface\n\n        BrowseInterface -&gt;&gt; BrowseService: 获取房源详情信息(房源编号)\n        activate BrowseService\n\n        BrowseService -&gt;&gt; House: 获取房源基础信息()\n        activate House\n        House --&gt;&gt; BrowseService: 返回名称、总价、均价、面积、户型、楼层等信息\n        deactivate House\n\n        BrowseService --&gt;&gt; BrowseInterface: 返回房源详情信息\n        deactivate BrowseService\n\n        BrowseInterface --&gt;&gt; BrowseController: 返回房源详情信息\n        deactivate BrowseInterface\n\n        BrowseController --&gt;&gt; QueryPage: 返回房源详情信息\n        deactivate BrowseController\n\n        QueryPage -&gt;&gt; DetailPage: 显示房源详情(房源)\n        activate DetailPage\n        DetailPage --&gt;&gt; User: 展示房源详细信息\n    end\n\n    Note over User,LocationInfo: 查看位置与周边配套\n\n    opt 用户查看位置与周边配套\n        User -&gt;&gt; DetailPage: 查看位置与周边配套()\n\n        DetailPage -&gt;&gt; BrowseController: 查看位置与周边配套(房源编号)\n        activate BrowseController\n\n        BrowseController -&gt;&gt; BrowseInterface: 获取房源配套信息(房源编号)\n        activate BrowseInterface\n\n        BrowseInterface -&gt;&gt; BrowseService: 获取房源配套信息(房源编号)\n        activate BrowseService\n\n        BrowseService -&gt;&gt; LocationInfo: 获取周边配套信息()\n        activate LocationInfo\n        LocationInfo --&gt;&gt; BrowseService: 返回交通、教育、商业、医疗等配套信息\n        deactivate LocationInfo\n\n        BrowseService --&gt;&gt; BrowseInterface: 返回位置与周边配套信息\n        deactivate BrowseService\n\n        BrowseInterface --&gt;&gt; BrowseController: 返回位置与周边配套信息\n        deactivate BrowseInterface\n\n        BrowseController --&gt;&gt; DetailPage: 返回位置与周边配套信息\n        deactivate BrowseController\n\n        DetailPage --&gt;&gt; User: 展示地图位置与周边配套\n        deactivate DetailPage\n    end\n\n    deactivate QueryPage&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="rirNdWmTbXj5kuHQcFEE-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry height="17021" width="1395" as="geometry" />
          </mxCell>
        </UserObject>
