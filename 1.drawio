        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\ndirection LR\n\nclass 用户 {\n  -用户编号: String\n  -用户名: String\n  -角色名称: String\n  +进入系统(): void\n  +退出系统(): void\n}\n\nclass 普通用户 {\n  -查询次数: int\n  -最近查询时间: String\n  +进入房源探索(): void\n  +提交筛选条件(): void\n  +选择目标房源(房源编号: String): void\n}\n\nclass 查询房源边界类 {\n  &lt;&lt;abstract&gt;&gt;\n  -查询房源控制器: 查询房源控制器\n  -提示信息: String\n  +提交概况请求(区域名称: String): void\n  +提交筛选请求(c: 筛选条件): void\n  +提交详情请求(房源编号: String): void\n  +展示提示信息(msg: String): void\n}\n\nclass 区域房源概况页面 {\n  &lt;&lt;abstract&gt;&gt;\n  -当前区域名称: String\n  -当前概况统计: 区域房源概况统计\n  +展示区域概况(g: 区域房源概况统计): void\n}\n\nclass 省级房源概况页面 {\n  -当前省份名称: String\n  +展示省级概况(g: 区域房源概况统计): void\n  +选择城市(城市名称: String): void\n}\n\nclass 城市房源概况页面 {\n  -当前城市名称: String\n  +展示城市概况(g: 区域房源概况统计): void\n  +选择地区(地区名称: String): void\n}\n\nclass 地区房源概况页面 {\n  -当前地区名称: String\n  +展示地区概况(g: 区域房源概况统计): void\n  +进入房源筛选(c: 筛选条件): void\n}\n\nclass 房源筛选列表页面 {\n  -当前筛选条件: 筛选条件\n  -当前房源列表: List~房源列表项~\n  -当前页码: int\n  -每页数量: int\n  +接收筛选条件(c: 筛选条件): void\n  +展示房源列表(list: List~房源列表项~): void\n  +选择房源(房源编号: String): void\n  +展示无匹配结果(): void\n}\n\nclass 房源详细信息页面 {\n  -当前房源列表项: 房源列表项\n  -当前房源详细信息: 房源详细信息\n  +展示房源列表项(item: 房源列表项): void\n  +展示房源详细信息(d: 房源详细信息): void\n  +展示位置和配套概述(d: 房源详细信息): void\n  +提交地图请求(房源编号: String): void\n  +进入地图页面(房源编号: String): void\n}\n\nclass 地图位置配套页面 {\n  -当前地图位置配套: 地图详细位置与周边配套\n  +展示地图位置(p: 地图详细位置与周边配套): void\n  +展示周边配套(p: 地图详细位置与周边配套): void\n}\n\nclass 查询房源控制器 {\n  -查询房源服务: I查询房源服务\n  -地图位置配套服务: I地图位置配套服务\n  -当前页码: int\n  -每页数量: int\n  +查看省级房源概况(省份名称: String): 区域房源概况统计\n  +查看城市房源概况(城市名称: String): 区域房源概况统计\n  +查看地区房源概况(地区名称: String): 区域房源概况统计\n  +筛选地区房源(c: 筛选条件): List~房源列表项~\n  +查看房源详细信息(房源编号: String): 房源详细信息\n  +查看地图详细位置与周边配套(房源编号: String): 地图详细位置与周边配套\n}\n\nclass I查询房源服务 {\n  &lt;&lt;interface&gt;&gt;\n  +获取省级房源概况(省份名称: String): 区域房源概况统计\n  +获取城市房源概况(城市名称: String): 区域房源概况统计\n  +获取地区房源概况(地区名称: String): 区域房源概况统计\n  +按条件筛选(c: 筛选条件): List~房源列表项~\n  +获取房源详细信息(房源编号: String): 房源详细信息\n  +判断房源是否存在(房源编号: String): boolean\n}\n\nclass 查询房源服务 {\n  -服务名称: String\n  -最大返回数量: int\n  +获取省级房源概况(省份名称: String): 区域房源概况统计\n  +获取城市房源概况(城市名称: String): 区域房源概况统计\n  +获取地区房源概况(地区名称: String): 区域房源概况统计\n  +按条件筛选(c: 筛选条件): List~房源列表项~\n  +获取房源详细信息(房源编号: String): 房源详细信息\n  +判断房源是否存在(房源编号: String): boolean\n  +统计区域房源(list: List~房源列表项~): 区域房源概况统计\n}\n\nclass I地图位置配套服务 {\n  &lt;&lt;interface&gt;&gt;\n  +获取地图详细位置(房源编号: String): 地图详细位置与周边配套\n  +获取周边配套详情(房源编号: String): 地图详细位置与周边配套\n  +判断地图服务是否可用(): boolean\n}\n\nclass 地图位置配套服务适配类 {\n  -服务名称: String\n  -默认查询范围: double\n  -服务状态: String\n  +获取地图详细位置(房源编号: String): 地图详细位置与周边配套\n  +获取周边配套详情(房源编号: String): 地图详细位置与周边配套\n  +判断地图服务是否可用(): boolean\n}\n\nclass 省份 {\n  -省份编号: String\n  -省份名称: String\n  -房源数量: int\n  +统计房源数量(): int\n}\n\nclass 城市 {\n  -城市编号: String\n  -城市名称: String\n  -房源数量: int\n  -平均房价: double\n  +统计房源数量(): int\n  +统计平均房价(): double\n}\n\nclass 地区 {\n  -地区编号: String\n  -地区名称: String\n  -所属城市: String\n  -区域均价: double\n  +统计区域均价(): double\n  +统计区域房源数量(): int\n}\n\nclass 小区 {\n  -小区编号: String\n  -小区名称: String\n  -所属地区: String\n  -位置概述: String\n  -挂牌数量: int\n  +统计挂牌数量(): int\n  +生成小区说明(): String\n}\n\nclass 区域房源概况统计 {\n  -概况编号: String\n  -统计层级: String\n  -区域名称: String\n  -房源总数: int\n  -平均房价: double\n  -最高房价: double\n  -最低房价: double\n  -热门区域说明: String\n  -价格分布说明: String\n  +生成概况说明(): String\n  +判断是否为空(): boolean\n}\n\nclass 筛选条件 {\n  -装修情况: String\n  -楼层范围: String\n  -产权情况: String\n  -抵押情况: String\n  -最小面积: double\n  -最大面积: double\n  -最低房价: double\n  -最高房价: double\n  +是否完整(): boolean\n  +是否合理(): boolean\n  +是否匹配(item: 房源列表项): boolean\n  +清空条件(): void\n}\n\nclass 房源列表项 {\n  -房源编号: String\n  -小区名称: String\n  -房源标题: String\n  -楼层信息: String\n  -产权情况: String\n  -抵押情况: String\n  -建筑面积: double\n  -房价: double\n  -发布日期: String\n  +生成列表摘要(): String\n}\n\nclass 房源详细信息 {\n  -详情编号: String\n  -房源编号: String\n  -小区名称: String\n  -房源标题: String\n  -装修情况: String\n  -楼层信息: String\n  -产权情况: String\n  -抵押情况: String\n  -建筑面积: double\n  -房价: double\n  -发布日期: String\n  -户型: String\n  -朝向: String\n  -单价: double\n  -建筑年代: String\n  -房屋用途: String\n  -产权年限: String\n  -位置概述: String\n  -周边配套概述: String\n  -房源描述: String\n  +检查详情完整性(): boolean\n  +生成详情说明(): String\n}\n\nclass 地图详细位置与周边配套 {\n  -位置配套编号: String\n  -房源编号: String\n  -详细地址: String\n  -经度: double\n  -纬度: double\n  -地图位置说明: String\n  -交通说明: String\n  -学校说明: String\n  -医院说明: String\n  -商业说明: String\n  -生活服务说明: String\n  +判断位置是否可用(): boolean\n  +判断配套是否可用(): boolean\n  +生成位置配套说明(): String\n}\n\n用户 &lt;|-- 普通用户 : 泛化\n\n普通用户 \&quot;1\&quot; --&gt; \&quot;1\&quot; 查询房源边界类 : 关联\n\n查询房源边界类 &lt;|-- 区域房源概况页面 : 泛化\n查询房源边界类 &lt;|-- 房源筛选列表页面 : 泛化\n查询房源边界类 &lt;|-- 房源详细信息页面 : 泛化\n\n区域房源概况页面 &lt;|-- 省级房源概况页面 : 泛化\n区域房源概况页面 &lt;|-- 城市房源概况页面 : 泛化\n区域房源概况页面 &lt;|-- 地区房源概况页面 : 泛化\n\n省级房源概况页面 \&quot;1\&quot; ..&gt; \&quot;0..1\&quot; 城市房源概况页面 : 依赖\n城市房源概况页面 \&quot;1\&quot; ..&gt; \&quot;0..1\&quot; 地区房源概况页面 : 依赖\n地区房源概况页面 \&quot;1\&quot; ..&gt; \&quot;0..1\&quot; 房源筛选列表页面 : 依赖\n房源筛选列表页面 \&quot;1\&quot; ..&gt; \&quot;0..1\&quot; 房源详细信息页面 : 依赖\n房源详细信息页面 \&quot;1\&quot; ..&gt; \&quot;0..1\&quot; 地图位置配套页面 : 依赖\n\n查询房源边界类 \&quot;1\&quot; --&gt; \&quot;1\&quot; 查询房源控制器 : 关联\n\n查询房源控制器 \&quot;1\&quot; ..&gt; \&quot;1\&quot; I查询房源服务 : 依赖\n查询房源控制器 \&quot;1\&quot; ..&gt; \&quot;1\&quot; I地图位置配套服务 : 依赖\n\nI查询房源服务 &lt;|.. 查询房源服务 : 实现\nI地图位置配套服务 &lt;|.. 地图位置配套服务适配类 : 实现\n\n区域房源概况页面 \&quot;1\&quot; --&gt; \&quot;1\&quot; 区域房源概况统计 : 关联\n房源筛选列表页面 \&quot;1\&quot; --&gt; \&quot;1\&quot; 筛选条件 : 关联\n房源筛选列表页面 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 房源列表项 : 关联\n房源详细信息页面 \&quot;1\&quot; --&gt; \&quot;1\&quot; 房源列表项 : 关联\n房源详细信息页面 \&quot;1\&quot; --&gt; \&quot;1\&quot; 房源详细信息 : 关联\n地图位置配套页面 \&quot;1\&quot; --&gt; \&quot;1\&quot; 地图详细位置与周边配套 : 关联\n\n查询房源服务 \&quot;1\&quot; ..&gt; \&quot;1\&quot; 区域房源概况统计 : 依赖\n查询房源服务 \&quot;1\&quot; ..&gt; \&quot;1\&quot; 筛选条件 : 依赖\n查询房源服务 \&quot;1\&quot; ..&gt; \&quot;0..*\&quot; 房源列表项 : 依赖\n查询房源服务 \&quot;1\&quot; ..&gt; \&quot;0..1\&quot; 房源详细信息 : 依赖\n地图位置配套服务适配类 \&quot;1\&quot; ..&gt; \&quot;0..1\&quot; 地图详细位置与周边配套 : 依赖\n\n省份 \&quot;1\&quot; o-- \&quot;1..*\&quot; 城市 : 聚合\n城市 \&quot;1\&quot; o-- \&quot;1..*\&quot; 地区 : 聚合\n地区 \&quot;1\&quot; o-- \&quot;0..*\&quot; 小区 : 聚合\n小区 \&quot;1\&quot; o-- \&quot;0..*\&quot; 房源列表项 : 聚合\n\n筛选条件 \&quot;1\&quot; ..&gt; \&quot;0..*\&quot; 房源列表项 : 依赖\n房源列表项 \&quot;1\&quot; *-- \&quot;0..1\&quot; 房源详细信息 : 组合\n房源详细信息 \&quot;1\&quot; *-- \&quot;0..1\&quot; 地图详细位置与周边配套 : 组合&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="rvZjHZs7JUC4JIlDZKwR-2876">
