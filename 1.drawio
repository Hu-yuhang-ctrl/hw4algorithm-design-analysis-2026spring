        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\ndirection LR\n\nclass 用户 {\n  &lt;&lt;actor&gt;&gt;\n  +用户编号: Long\n  +用户名: String\n  +用户角色: String\n  +进入系统(): void\n  +退出系统(): void\n}\n\nclass 系统管理员 {\n  &lt;&lt;actor&gt;&gt;\n  +管理范围: String\n  +异常处理状态: String\n  +查看系统状态(): void\n  +维护基础业务配置(): void\n  +管理用户与权限(): void\n  +处理异常信息(): void\n}\n\n用户 &lt;|-- 系统管理员 : 泛化\n\n\nclass 系统基础管理界面 {\n  &lt;&lt;boundary&gt;&gt;\n  +当前管理事项: String\n  +当前管理员: 系统管理员\n  +显示管理事项(): void\n  +显示系统状态(系统状态: 系统状态): void\n  +显示基础业务配置(配置列表: List~基础业务配置~): void\n  +显示用户与权限信息(权限信息: 用户与权限信息): void\n  +显示异常信息(异常列表: List~异常信息~): void\n  +显示处理结果(处理结果: String): void\n}\n\n\nclass 系统基础管理控制类 {\n  &lt;&lt;control&gt;&gt;\n  +查看系统状态(): 系统状态\n  +维护基础业务配置(配置项: 基础业务配置): Boolean\n  +管理用户与权限(权限信息: 用户与权限信息): Boolean\n  +处理异常信息(异常信息: 异常信息): Boolean\n}\n\n\nclass 系统状态查看接口 {\n  &lt;&lt;interface&gt;&gt;\n  +获取系统状态(): 系统状态\n  +汇总运行情况(): 系统状态\n  +判断系统是否异常(系统状态: 系统状态): Boolean\n}\n\nclass 基础业务配置接口 {\n  &lt;&lt;interface&gt;&gt;\n  +新增配置项(配置项: 基础业务配置): Boolean\n  +修改配置项(配置项: 基础业务配置): Boolean\n  +停用配置项(配置编号: Long): Boolean\n  +检查配置有效性(配置项: 基础业务配置): Boolean\n}\n\nclass 用户权限管理接口 {\n  &lt;&lt;interface&gt;&gt;\n  +新增用户(权限信息: 用户与权限信息): Boolean\n  +调整用户权限(权限信息: 用户与权限信息): Boolean\n  +启用或禁用用户(用户编号: Long, 用户状态: 用户状态): Boolean\n  +检查权限配置(权限信息: 用户与权限信息): Boolean\n}\n\nclass 异常信息处理接口 {\n  &lt;&lt;interface&gt;&gt;\n  +获取异常列表(): List~异常信息~\n  +确认异常原因(异常信息: 异常信息): String\n  +处理异常信息(异常信息: 异常信息): Boolean\n  +更新异常状态(异常编号: Long, 处理状态: 异常处理状态): Boolean\n}\n\n\nclass 系统状态查看服务类 {\n  &lt;&lt;service&gt;&gt;\n  +获取系统状态(): 系统状态\n  +汇总运行情况(): 系统状态\n  +判断系统是否异常(系统状态: 系统状态): Boolean\n}\n\nclass 基础业务配置服务类 {\n  &lt;&lt;service&gt;&gt;\n  +新增配置项(配置项: 基础业务配置): Boolean\n  +修改配置项(配置项: 基础业务配置): Boolean\n  +停用配置项(配置编号: Long): Boolean\n  +检查配置有效性(配置项: 基础业务配置): Boolean\n}\n\nclass 用户权限管理服务类 {\n  &lt;&lt;service&gt;&gt;\n  +新增用户(权限信息: 用户与权限信息): Boolean\n  +调整用户权限(权限信息: 用户与权限信息): Boolean\n  +启用或禁用用户(用户编号: Long, 用户状态: 用户状态): Boolean\n  +检查权限配置(权限信息: 用户与权限信息): Boolean\n}\n\nclass 异常信息处理服务类 {\n  &lt;&lt;service&gt;&gt;\n  +获取异常列表(): List~异常信息~\n  +确认异常原因(异常信息: 异常信息): String\n  +处理异常信息(异常信息: 异常信息): Boolean\n  +更新异常状态(异常编号: Long, 处理状态: 异常处理状态): Boolean\n}\n\n\nclass 系统状态 {\n  &lt;&lt;entity&gt;&gt;\n  +状态编号: Long\n  +运行情况: String\n  +异常提示: String\n  +系统运行状态: 系统运行状态\n  +检查时间: DateTime\n  +反馈运行情况(): String\n  +提示异常信息(): List~异常信息~\n}\n\nclass 系统运行状态 {\n  &lt;&lt;enumeration&gt;&gt;\n  正常\n  异常\n  维护中\n  不可用\n}\n\n\nclass 基础业务配置 {\n  &lt;&lt;entity&gt;&gt;\n  +配置编号: Long\n  +配置名称: String\n  +配置值: String\n  +配置说明: String\n  +配置状态: 配置状态\n  +创建时间: DateTime\n  +检查配置有效性(): Boolean\n  +更新配置(): Boolean\n}\n\nclass 配置状态 {\n  &lt;&lt;enumeration&gt;&gt;\n  启用\n  停用\n  待校验\n  配置异常\n}\n\n\nclass 用户与权限信息 {\n  &lt;&lt;entity&gt;&gt;\n  +用户编号: Long\n  +用户账号: String\n  +用户姓名: String\n  +角色名称: String\n  +权限范围: String\n  +用户状态: 用户状态\n  +检查用户信息(): Boolean\n  +检查权限配置(): Boolean\n  +保存权限调整(): Boolean\n}\n\nclass 用户状态 {\n  &lt;&lt;enumeration&gt;&gt;\n  启用\n  禁用\n  待创建\n  信息无效\n}\n\n\nclass 异常信息 {\n  &lt;&lt;entity&gt;&gt;\n  +异常编号: Long\n  +异常来源: String\n  +异常原因: String\n  +异常级别: String\n  +处理状态: 异常处理状态\n  +处理说明: String\n  +发生时间: DateTime\n  +确认异常原因(): String\n  +记录处理结果(): Boolean\n}\n\nclass 异常处理状态 {\n  &lt;&lt;enumeration&gt;&gt;\n  待处理\n  原因待确认\n  处理中\n  已处理\n  待继续处理\n}\n\n\nclass 管理操作记录 {\n  &lt;&lt;entity&gt;&gt;\n  +记录编号: Long\n  +操作类型: String\n  +操作对象: String\n  +操作人员: String\n  +操作时间: DateTime\n  +操作结果: String\n  +生成管理记录(): String\n}\n\n\n系统管理员 -- 系统基础管理界面 : 关联\n\n系统基础管理界面 ..&gt; 系统基础管理控制类 : 依赖\n\n系统基础管理控制类 ..&gt; 系统状态查看接口 : 依赖\n系统基础管理控制类 ..&gt; 基础业务配置接口 : 依赖\n系统基础管理控制类 ..&gt; 用户权限管理接口 : 依赖\n系统基础管理控制类 ..&gt; 异常信息处理接口 : 依赖\n\n系统状态查看接口 &lt;|.. 系统状态查看服务类 : 实现\n基础业务配置接口 &lt;|.. 基础业务配置服务类 : 实现\n用户权限管理接口 &lt;|.. 用户权限管理服务类 : 实现\n异常信息处理接口 &lt;|.. 异常信息处理服务类 : 实现\n\n系统状态查看服务类 ..&gt; 系统状态 : 依赖\n基础业务配置服务类 ..&gt; 基础业务配置 : 依赖\n用户权限管理服务类 ..&gt; 用户与权限信息 : 依赖\n异常信息处理服务类 ..&gt; 异常信息 : 依赖\n\n基础业务配置服务类 ..&gt; 管理操作记录 : 依赖\n用户权限管理服务类 ..&gt; 管理操作记录 : 依赖\n异常信息处理服务类 ..&gt; 管理操作记录 : 依赖\n\n系统状态 -- 系统运行状态 : 关联\n基础业务配置 -- 配置状态 : 关联\n用户与权限信息 -- 用户状态 : 关联\n异常信息 -- 异常处理状态 : 关联\n\n系统状态 -- 异常信息 : 关联\n系统管理员 -- 管理操作记录 : 关联&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="rvZjHZs7JUC4JIlDZKwR-5694">
