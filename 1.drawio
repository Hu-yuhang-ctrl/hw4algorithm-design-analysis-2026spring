        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\ndirection LR\n\nclass 用户 {\n  &lt;&lt;actor&gt;&gt;\n  +用户编号: Long\n  +用户名: String\n  +用户角色: String\n  +进入系统(): void\n  +退出系统(): void\n}\n\nclass 普通用户 {\n  &lt;&lt;actor&gt;&gt;\n  +预测需求: String\n  +填写房源特征(): void\n  +调整预测条件(): void\n  +提交预测请求(): void\n  +查看预测结果(): void\n}\n\n用户 &lt;|-- 普通用户 : 泛化\n\n\nclass 房价预测界面 {\n  &lt;&lt;boundary&gt;&gt;\n  +页面标题: String\n  +当前预测条件: 房源预测条件\n  +当前预测结果: 预测结果\n  +显示预测表单(): void\n  +接收房源特征(预测条件: 房源预测条件): void\n  +接收调整条件(预测条件: 房源预测条件): void\n  +显示预测结果(预测结果: 预测结果): void\n  +显示结果说明(说明: String): void\n}\n\n\nclass 房价预测控制类 {\n  &lt;&lt;control&gt;&gt;\n  +提交预测请求(预测条件: 房源预测条件): 预测结果\n  +检查预测条件(预测条件: 房源预测条件): Boolean\n  +返回预测结果(预测结果: 预测结果): void\n}\n\n\nclass 房价预测服务接口 {\n  &lt;&lt;interface&gt;&gt;\n  +校验预测条件(预测条件: 房源预测条件): Boolean\n  +生成预测请求(预测条件: 房源预测条件): 预测请求\n  +执行价格预测(预测请求: 预测请求): 预测结果\n  +生成结果说明(预测结果: 预测结果): String\n}\n\n\nclass 房价预测服务类 {\n  &lt;&lt;service&gt;&gt;\n  +校验预测条件(预测条件: 房源预测条件): Boolean\n  +生成预测请求(预测条件: 房源预测条件): 预测请求\n  +执行价格预测(预测请求: 预测请求): 预测结果\n  +生成结果说明(预测结果: 预测结果): String\n}\n\n\nclass 房源预测条件 {\n  &lt;&lt;valueObject&gt;&gt;\n  +省份名称: String\n  +城市名称: String\n  +地区名称: String\n  +面积: Double\n  +户型: String\n  +楼层: String\n  +朝向: String\n  +装修: String\n  +建筑类型: String\n  +房屋年限: Integer\n  +是否有电梯: Boolean\n  +是否有效(): Boolean\n}\n\n\nclass 预测请求 {\n  &lt;&lt;entity&gt;&gt;\n  +请求编号: Long\n  +请求状态: 预测请求状态\n  +提交时间: DateTime\n  +检查信息完整性(): Boolean\n  +检查信息合理性(): Boolean\n  +形成评估依据(): String\n}\n\n\nclass 预测请求状态 {\n  &lt;&lt;enumeration&gt;&gt;\n  待填写\n  待检查\n  待补充\n  可评估\n  不可评估\n  已反馈\n}\n\n\nclass 价格模型 {\n  &lt;&lt;entity&gt;&gt;\n  +模型编号: Long\n  +模型名称: String\n  +模型版本: String\n  +模型状态: String\n  +训练时间: DateTime\n  +加载模型(): Boolean\n  +输出预测价格(预测请求: 预测请求): Double\n}\n\n\nclass 预测结果 {\n  &lt;&lt;entity&gt;&gt;\n  +结果编号: Long\n  +参考价格: Double\n  +价格区间: String\n  +结果说明: String\n  +反馈状态: 预测结果状态\n  +生成时间: DateTime\n  +反馈参考价格(): String\n  +说明预测结果(): String\n}\n\n\nclass 预测结果状态 {\n  &lt;&lt;enumeration&gt;&gt;\n  待生成\n  已生成\n  已展示\n  已失效\n}\n\n\nclass 模型报告 {\n  &lt;&lt;entity&gt;&gt;\n  +报告编号: Long\n  +模型名称: String\n  +模型版本: String\n  +样本数量: Integer\n  +平均绝对误差: Double\n  +均方根误差: Double\n  +决定系数: Double\n  +生成报告(): String\n}\n\n\n普通用户 -- 房价预测界面 : 关联\n\n房价预测界面 ..&gt; 房价预测控制类 : 依赖\n房价预测控制类 ..&gt; 房价预测服务接口 : 依赖\n\n房价预测服务接口 &lt;|.. 房价预测服务类 : 实现\n\n房价预测界面 -- 房源预测条件 : 关联\n房价预测控制类 -- 房源预测条件 : 关联\n房价预测服务类 -- 房源预测条件 : 关联\n\n预测请求 \&quot;1\&quot; *-- \&quot;1\&quot; 房源预测条件 : 组合\n预测请求 \&quot;1\&quot; *-- \&quot;0..1\&quot; 预测结果 : 组合\n\n房价预测服务类 -- 预测请求 : 关联\n房价预测服务类 -- 价格模型 : 关联\n房价预测服务类 -- 预测结果 : 关联\n\n价格模型 -- 预测结果 : 关联\n价格模型 -- 模型报告 : 关联\n\n预测请求 -- 预测请求状态 : 关联\n预测结果 -- 预测结果状态 : 关联\n\n房价预测界面 -- 预测结果 : 关联\n房价预测界面 -- 模型报告 : 关联&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="rvZjHZs7JUC4JIlDZKwR-5160">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=1;groupPadding=20;" vertex="1">
            <mxGeometry height="40005" width="3981" as="geometry" />
          </mxCell>
        </UserObject>
