        <mxCell id="IWdd7cq-W41f84VaV7Cw-260" parent="IWdd7cq-W41f84VaV7Cw-261" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#000000;" value="" vertex="1">
          <mxGeometry height="50" width="50" x="6" y="6" as="geometry" />
        </mxCell>
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\ndirection LR\n\nnamespace 枚举类型 {\n    class 用户状态 {\n        &lt;&lt;enumeration&gt;&gt;\n        启用\n        禁用\n        锁定\n    }\n\n    class 请求状态 {\n        &lt;&lt;enumeration&gt;&gt;\n        待填写\n        已提交\n        校验失败\n        可预测\n        预测成功\n        预测失败\n        已结束\n    }\n\n    class 资料状态 {\n        &lt;&lt;enumeration&gt;&gt;\n        原始\n        待补充\n        待整理\n        异常\n        已更新\n        已标准化\n    }\n\n    class 异常类型 {\n        &lt;&lt;enumeration&gt;&gt;\n        字段缺失\n        格式不规范\n        数值异常\n        重复数据\n        无效数据\n    }\n}\n\nnamespace 用户角色 {\n    class 用户 {\n        &lt;&lt;abstract&gt;&gt;\n        #用户编号: Long\n        #用户身份: String\n        #使用状态: 用户状态\n        #创建时间: DateTime\n        #最近登录时间: DateTime\n        +进入系统(): Boolean\n        +退出系统(): void\n        +获取用户身份(): String\n        +判断用户是否可用(): Boolean\n    }\n\n    class 普通用户 {\n        -找房需求: String\n        -预测需求: String\n        +查询房源(condition: 筛选条件): List~房源~\n        +提交预测请求(request: 预测请求): 预测结果\n    }\n\n    class 数据维护人员 {\n        -维护范围: String\n        -维护任务: String\n        +确定维护范围(range: String): void\n        +核查房源资料(material: 房源维护资料): 核查结果\n        +维护房源资料(material: 房源维护资料): Boolean\n    }\n\n    class 系统管理员 {\n        -管理范围: String\n        -异常处理职责: String\n        +查看系统状态(): 系统状态\n        +处理异常信息(record: 维护记录): Boolean\n    }\n}\n\nnamespace 边界类 {\n    class 房源查询界面 {\n        &lt;&lt;boundary&gt;&gt;\n        -当前页码: Integer\n        -每页数量: Integer\n        -当前筛选条件: 筛选条件\n        +接收查询条件(): 筛选条件\n        +显示房源列表(houses: List~房源~): void\n        +显示房源详情(house: 房源): void\n        +显示位置与配套(info: 详细位置和周边配套): void\n        +显示空结果提示(): void\n    }\n\n    class 房价预测界面 {\n        &lt;&lt;boundary&gt;&gt;\n        -表单数据: Map\n        -当前预测请求: 预测请求\n        +接收房源特征(): 预测请求\n        +显示校验错误(message: String): void\n        +显示预测结果(result: 预测结果): void\n        +返回填写环节(): void\n    }\n\n    class 房源维护界面 {\n        &lt;&lt;boundary&gt;&gt;\n        -当前维护范围: String\n        -当前资料状态: 资料状态\n        +接收维护范围(): String\n        +显示待维护资料(materials: List~房源维护资料~): void\n        +显示核查结果(result: 核查结果): void\n        +提交维护结果(material: 房源维护资料): Boolean\n    }\n\n    class 系统管理界面 {\n        &lt;&lt;boundary&gt;&gt;\n        -当前系统状态: 系统状态\n        +显示系统状态(status: 系统状态): void\n        +显示异常信息(messages: List~String~): void\n        +提交异常处理结果(record: 维护记录): Boolean\n    }\n}\n\nnamespace 控制类 {\n    class 房源查询控制器 {\n        &lt;&lt;control&gt;&gt;\n        +查询房源(condition: 筛选条件): List~房源~\n        +查看房源详情(houseId: Long): 房源\n        +查看位置与配套(houseId: Long): 详细位置和周边配套\n        -校验筛选条件(condition: 筛选条件): Boolean\n        -组织房源列表(houses: List~房源~): List~房源~\n    }\n\n    class 房价预测控制器 {\n        &lt;&lt;control&gt;&gt;\n        +提交预测请求(request: 预测请求): 预测结果\n        +调整预测条件(request: 预测请求): 预测请求\n        -校验预测信息(request: 预测请求): Boolean\n        -生成特征数据(request: 预测请求): 模型特征数据\n        -保存预测记录(request: 预测请求, result: 预测结果): void\n    }\n\n    class 房源维护控制器 {\n        &lt;&lt;control&gt;&gt;\n        +确定维护范围(range: String): List~房源维护资料~\n        +核查房源信息(material: 房源维护资料): 核查结果\n        +补充房源资料(material: 房源维护资料): 房源维护资料\n        +整理房源资料(material: 房源维护资料): 房源维护资料\n        +处理异常资料(abnormal: 异常资料): 异常资料\n        +更新房源信息(material: 房源维护资料): Boolean\n        -记录维护日志(record: 维护记录): void\n    }\n\n    class 系统管理控制器 {\n        &lt;&lt;control&gt;&gt;\n        +查看系统状态(): 系统状态\n        +处理异常信息(record: 维护记录): Boolean\n        -生成异常提示(status: 系统状态): List~String~\n    }\n}\n\nnamespace 实体类 {\n    class 筛选条件 {\n        &lt;&lt;entity&gt;&gt;\n        -条件编号: Long\n        -区域范围: String\n        -最低价格: BigDecimal\n        -最高价格: BigDecimal\n        -最小面积: Double\n        -最大面积: Double\n        -户型要求: String\n        -朝向要求: String\n        -楼层要求: String\n        -装修要求: String\n        +校验条件(): Boolean\n        +调整条件(newCondition: 筛选条件): void\n        +生成查询条件(): Map\n    }\n\n    class 房源 {\n        &lt;&lt;entity&gt;&gt;\n        -房源编号: Long\n        -房源名称: String\n        -总价: BigDecimal\n        -单价: BigDecimal\n        -面积: Double\n        -户型: String\n        -楼层: String\n        -朝向: String\n        -装修: String\n        -建筑结构: String\n        -产权性质: String\n        -挂牌时间: Date\n        -经度: Double\n        -纬度: Double\n        -当前资料状态: 资料状态\n        -更新时间: DateTime\n        +展示基本信息(): String\n        +展示详细信息(): String\n        +参与价格参考(): Boolean\n        +更新房源信息(data: Map): void\n        +判断资料是否有效(): Boolean\n    }\n\n    class 详细位置和周边配套 {\n        &lt;&lt;entity&gt;&gt;\n        -配套编号: Long\n        -地图位置: String\n        -交通配套: String\n        -教育配套: String\n        -医疗配套: String\n        -商业配套: String\n        -居住便利度: String\n        +展示详细位置(): String\n        +展示周边配套信息(): String\n        +辅助居住判断(): String\n    }\n\n    class 城市 {\n        &lt;&lt;entity&gt;&gt;\n        -城市编号: Long\n        -城市名称: String\n        -房源数量: Integer\n        -平均价格: BigDecimal\n        +汇总房源情况(): Map\n    }\n\n    class 地区 {\n        &lt;&lt;entity&gt;&gt;\n        -地区编号: Long\n        -地区名称: String\n        -房源数量: Integer\n        -价格水平: BigDecimal\n        +统计地区房源(): Map\n    }\n\n    class 小区 {\n        &lt;&lt;entity&gt;&gt;\n        -小区编号: Long\n        -小区名称: String\n        -所属区域: String\n        -房源数量: Integer\n        +归集房源(): List~房源~\n    }\n\n    class 预测请求 {\n        &lt;&lt;entity&gt;&gt;\n        -请求编号: Long\n        -用户编号: Long\n        -房源特征: Map\n        -当前请求状态: 请求状态\n        -预测目的: String\n        -提交时间: DateTime\n        +检查信息完整性(): Boolean\n        +检查信息合理性(): Boolean\n        +形成评估依据(): 模型特征数据\n    }\n\n    class 模型特征数据 {\n        &lt;&lt;entity&gt;&gt;\n        -特征编号: Long\n        -类别特征向量: List~Integer~\n        -数值特征向量: List~Double~\n        -标准化结果: List~Double~\n        +编码类别特征(): List~Integer~\n        +标准化数值特征(): List~Double~\n        +生成输入矩阵(): List~Double~\n    }\n\n    class 预测结果 {\n        &lt;&lt;entity&gt;&gt;\n        -结果编号: Long\n        -请求编号: Long\n        -参考价格: BigDecimal\n        -结果说明: String\n        -反馈状态: String\n        -生成时间: DateTime\n        +反馈参考价格(): BigDecimal\n        +说明预测结果(): String\n    }\n\n    class 房源维护资料 {\n        &lt;&lt;entity&gt;&gt;\n        -资料编号: Long\n        -资料来源: String\n        -当前资料状态: 资料状态\n        -完整性情况: String\n        -规范性情况: String\n        -维护时间: DateTime\n        +接受核查(): 核查结果\n        +接受整理(): 房源维护资料\n        +形成标准房源(): 房源\n    }\n\n    class 核查结果 {\n        &lt;&lt;entity&gt;&gt;\n        -结果编号: Long\n        -是否缺失: Boolean\n        -是否不规范: Boolean\n        -是否异常: Boolean\n        -核查说明: String\n        +是否通过(): Boolean\n        +生成处理建议(): String\n    }\n\n    class 异常资料 {\n        &lt;&lt;entity&gt;&gt;\n        -异常编号: Long\n        -异常原因: String\n        -异常状态: String\n        -当前异常类型: 异常类型\n        -处理结果: String\n        +标记异常(type: 异常类型): void\n        +确认异常(): Boolean\n        +处理异常(method: String): Boolean\n    }\n\n    class 维护记录 {\n        &lt;&lt;entity&gt;&gt;\n        -记录编号: Long\n        -维护事项: String\n        -处理结果: String\n        -记录时间: DateTime\n        -维护人员编号: Long\n        +记录维护过程(): void\n        +反馈处理结果(): String\n    }\n\n    class 系统状态 {\n        &lt;&lt;entity&gt;&gt;\n        -状态编号: Long\n        -运行情况: String\n        -异常提示: String\n        -可用状态: Boolean\n        -更新时间: DateTime\n        +反映运行情况(): String\n        +提示异常信息(): List~String~\n    }\n}\n\nnamespace 接口与实现 {\n    class 房源数据访问接口 {\n        &lt;&lt;interface&gt;&gt;\n        +findByCondition(condition: 筛选条件): List~房源~\n        +findById(houseId: Long): 房源\n        +save(house: 房源): Boolean\n        +update(house: 房源): Boolean\n        +findMaintenanceMaterials(range: String): List~房源维护资料~\n    }\n\n    class 房源数据访问实现 {\n        &lt;&lt;repository&gt;&gt;\n        -数据源: String\n        +findByCondition(condition: 筛选条件): List~房源~\n        +findById(houseId: Long): 房源\n        +save(house: 房源): Boolean\n        +update(house: 房源): Boolean\n        +findMaintenanceMaterials(range: String): List~房源维护资料~\n    }\n\n    class 地图服务接口 {\n        &lt;&lt;interface&gt;&gt;\n        +getLocation(house: 房源): 详细位置和周边配套\n        +searchNearby(lng: Double, lat: Double, radius: Integer): 详细位置和周边配套\n    }\n\n    class 百度地图服务实现 {\n        &lt;&lt;service&gt;&gt;\n        -百度地图AK: String\n        +getLocation(house: 房源): 详细位置和周边配套\n        +searchNearby(lng: Double, lat: Double, radius: Integer): 详细位置和周边配套\n    }\n\n    class 预测模型服务接口 {\n        &lt;&lt;interface&gt;&gt;\n        +loadModel(modelPath: String): Boolean\n        +transform(request: 预测请求): 模型特征数据\n        +predict(input: 模型特征数据): 预测结果\n    }\n\n    class 房价预测模型服务实现 {\n        &lt;&lt;service&gt;&gt;\n        -模型路径: String\n        -特征规则路径: String\n        +loadModel(modelPath: String): Boolean\n        +transform(request: 预测请求): 模型特征数据\n        +predict(input: 模型特征数据): 预测结果\n    }\n\n    class 系统状态服务接口 {\n        &lt;&lt;interface&gt;&gt;\n        +getCurrentStatus(): 系统状态\n        +getExceptionMessages(): List~String~\n    }\n\n    class 系统状态服务实现 {\n        &lt;&lt;service&gt;&gt;\n        +getCurrentStatus(): 系统状态\n        +getExceptionMessages(): List~String~\n    }\n}\n\n%% 泛化关系\n用户 &lt;|-- 普通用户 : 泛化\n用户 &lt;|-- 数据维护人员 : 泛化\n用户 &lt;|-- 系统管理员 : 泛化\n\n%% 实现关系\n房源数据访问接口 &lt;|.. 房源数据访问实现 : 实现\n地图服务接口 &lt;|.. 百度地图服务实现 : 实现\n预测模型服务接口 &lt;|.. 房价预测模型服务实现 : 实现\n系统状态服务接口 &lt;|.. 系统状态服务实现 : 实现\n\n%% 边界类到控制类：依赖\n房源查询界面 ..&gt; 房源查询控制器 : 依赖\n房价预测界面 ..&gt; 房价预测控制器 : 依赖\n房源维护界面 ..&gt; 房源维护控制器 : 依赖\n系统管理界面 ..&gt; 系统管理控制器 : 依赖\n\n%% 控制类到接口：依赖\n房源查询控制器 ..&gt; 房源数据访问接口 : 依赖\n房源查询控制器 ..&gt; 地图服务接口 : 依赖\n房价预测控制器 ..&gt; 预测模型服务接口 : 依赖\n房价预测控制器 ..&gt; 房源数据访问接口 : 依赖\n房源维护控制器 ..&gt; 房源数据访问接口 : 依赖\n系统管理控制器 ..&gt; 系统状态服务接口 : 依赖\n\n%% 枚举依赖\n用户 ..&gt; 用户状态 : 依赖\n预测请求 ..&gt; 请求状态 : 依赖\n房源 ..&gt; 资料状态 : 依赖\n房源维护资料 ..&gt; 资料状态 : 依赖\n异常资料 ..&gt; 异常类型 : 依赖\n\n%% 查询房源相关实体关系\n普通用户 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 筛选条件 : 关联\n筛选条件 ..&gt; 房源 : 依赖\n房源 \&quot;1\&quot; --&gt; \&quot;0..1\&quot; 详细位置和周边配套 : 关联\n\n城市 \&quot;1\&quot; o-- \&quot;0..*\&quot; 地区 : 聚合\n地区 \&quot;1\&quot; o-- \&quot;0..*\&quot; 小区 : 聚合\n小区 \&quot;1\&quot; o-- \&quot;0..*\&quot; 房源 : 聚合\n\n%% 预测房价相关实体关系\n普通用户 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 预测请求 : 关联\n预测请求 \&quot;1\&quot; *-- \&quot;1\&quot; 模型特征数据 : 组合\n预测请求 \&quot;1\&quot; *-- \&quot;0..1\&quot; 预测结果 : 组合\n预测请求 ..&gt; 房源 : 依赖\n预测结果 ..&gt; 房源 : 依赖\n\n%% 房源维护相关实体关系\n数据维护人员 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 房源维护资料 : 关联\n数据维护人员 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 维护记录 : 关联\n房源维护资料 \&quot;1\&quot; --&gt; \&quot;0..1\&quot; 房源 : 关联\n房源维护资料 \&quot;1\&quot; *-- \&quot;1\&quot; 核查结果 : 组合\n房源维护资料 \&quot;1\&quot; *-- \&quot;0..*\&quot; 异常资料 : 组合\n维护记录 \&quot;1\&quot; --&gt; \&quot;1\&quot; 房源维护资料 : 关联\n维护记录 \&quot;0..*\&quot; --&gt; \&quot;0..1\&quot; 异常资料 : 关联\n\n%% 系统管理相关实体关系\n系统管理员 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 系统状态 : 关联\n系统管理员 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 维护记录 : 关联&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="7eVDWPtCOEXNINBA27vf-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
