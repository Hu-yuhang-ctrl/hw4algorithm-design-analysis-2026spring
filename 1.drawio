        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;classDiagram\ndirection LR\n\nclass 用户 {\n  -用户编号: String\n  -用户名: String\n  -角色名称: String\n  +进入系统(): void\n  +退出系统(): void\n}\n\nclass 普通用户 {\n  -查询次数: int\n  -最近查询时间: String\n  +查看房源统计概况(): void\n  +输入筛选条件(): 筛选条件\n  +选择房源(房源编号: String): void\n  +查看详细位置和周边配套(房源编号: String): void\n}\n\nclass 查询房源边界类 {\n  -查询控制器: 查询控制器\n  -提示信息: String\n  +提交查询请求(c: 筛选条件): void\n  +提交详情请求(房源编号: String): void\n  +展示提示信息(msg: String): void\n}\n\nclass 房源统计概况页面 {\n  -当前统计概况: 房源统计概况\n  -当前城市名称: String\n  -当前地区名称: String\n  +展示整体统计概况(g: 房源统计概况): void\n  +展示城市统计概况(g: 房源统计概况): void\n  +展示地区统计概况(g: 房源统计概况): void\n  +进入房源列表(c: 筛选条件): void\n}\n\nclass 房源列表页面 {\n  -当前筛选条件: 筛选条件\n  -当前房源列表: List~房源~\n  -当前页码: int\n  -每页数量: int\n  +接收筛选条件(c: 筛选条件): void\n  +展示房源列表(list: List~房源~): void\n  +选择房源(房源编号: String): void\n  +展示无匹配结果(): void\n}\n\nclass 房源详情页面 {\n  -当前房源: 房源\n  -当前房源详情: 房源详情\n  -当前位置配套: 详细位置和周边配套\n  +展示房源基本信息(h: 房源): void\n  +展示房源详情(d: 房源详情): void\n  +展示详细位置和周边配套(p: 详细位置和周边配套): void\n}\n\nclass 查询控制器 {\n  -房源查询服务: I房源查询服务\n  -地图服务: I地图服务\n  -当前页码: int\n  -每页数量: int\n  +查看整体统计概况(): 房源统计概况\n  +查看城市统计概况(城市名称: String): 房源统计概况\n  +查看地区统计概况(地区名称: String): 房源统计概况\n  +查询房源(c: 筛选条件): List~房源~\n  +查看房源详情(房源编号: String): 房源详情\n  +查看详细位置和周边配套(房源编号: String): 详细位置和周边配套\n}\n\nclass I房源查询服务 {\n  &lt;&lt;interface&gt;&gt;\n  +获取整体统计概况(): 房源统计概况\n  +获取城市统计概况(城市名称: String): 房源统计概况\n  +获取地区统计概况(地区名称: String): 房源统计概况\n  +按条件筛选(c: 筛选条件): List~房源~\n  +获取房源详情(房源编号: String): 房源详情\n  +判断房源是否存在(房源编号: String): boolean\n}\n\nclass 房源查询服务 {\n  -服务名称: String\n  -最大返回数量: int\n  +获取整体统计概况(): 房源统计概况\n  +获取城市统计概况(城市名称: String): 房源统计概况\n  +获取地区统计概况(地区名称: String): 房源统计概况\n  +按条件筛选(c: 筛选条件): List~房源~\n  +获取房源详情(房源编号: String): 房源详情\n  +判断房源是否存在(房源编号: String): boolean\n  +统计候选房源(list: List~房源~): 房源统计概况\n}\n\nclass I地图服务 {\n  &lt;&lt;interface&gt;&gt;\n  +获取详细位置(房源编号: String): 详细位置和周边配套\n  +获取周边配套(房源编号: String): 详细位置和周边配套\n  +判断地图服务是否可用(): boolean\n}\n\nclass 地图服务适配类 {\n  -服务名称: String\n  -默认查询范围: double\n  -服务状态: String\n  +获取详细位置(房源编号: String): 详细位置和周边配套\n  +获取周边配套(房源编号: String): 详细位置和周边配套\n  +判断地图服务是否可用(): boolean\n}\n\nclass 城市 {\n  -城市编号: String\n  -城市名称: String\n  -房源数量: int\n  -平均总价: double\n  +统计房源数量(): int\n  +统计平均总价(): double\n}\n\nclass 地区 {\n  -地区编号: String\n  -地区名称: String\n  -所属城市: String\n  -区域均价: double\n  +统计区域均价(): double\n  +统计区域房源数量(): int\n}\n\nclass 小区 {\n  -小区编号: String\n  -小区名称: String\n  -所属地区: String\n  -位置概述: String\n  -挂牌数量: int\n  +统计挂牌数量(): int\n  +生成小区说明(): String\n}\n\nclass 房源 {\n  -房源编号: String\n  -房源标题: String\n  -所在城市: String\n  -所在地区: String\n  -所属小区: String\n  -位置概述: String\n  -总价: double\n  -单价: double\n  -建筑面积: double\n  -户型: String\n  -朝向: String\n  -所在楼层: String\n  -装修情况: String\n  +匹配筛选条件(c: 筛选条件): boolean\n  +生成列表摘要(): String\n}\n\nclass 房源详情 {\n  -详情编号: String\n  -房源编号: String\n  -建筑年代: String\n  -房屋用途: String\n  -产权年限: String\n  -挂牌时间: String\n  -核心卖点: String\n  -房源描述: String\n  -详情状态: String\n  +检查详情完整性(): boolean\n  +生成详情说明(): String\n}\n\nclass 房源统计概况 {\n  -概况编号: String\n  -统计范围: String\n  -房源总数: int\n  -平均总价: double\n  -平均单价: double\n  -最高总价: double\n  -最低总价: double\n  -主要区域说明: String\n  +生成概况说明(): String\n  +判断是否为空(): boolean\n}\n\nclass 筛选条件 {\n  -城市名称: String\n  -地区名称: String\n  -小区名称: String\n  -最低总价: double\n  -最高总价: double\n  -最低单价: double\n  -最高单价: double\n  -最小面积: double\n  -最大面积: double\n  -户型: String\n  -朝向: String\n  -楼层范围: String\n  -装修情况: String\n  -房屋用途: String\n  -产权年限: String\n  +是否完整(): boolean\n  +是否合理(): boolean\n  +是否匹配(h: 房源): boolean\n  +清空条件(): void\n}\n\nclass 详细位置和周边配套 {\n  -位置配套编号: String\n  -房源编号: String\n  -详细地址: String\n  -经度: double\n  -纬度: double\n  -地图位置说明: String\n  -交通说明: String\n  -学校说明: String\n  -医院说明: String\n  -商业说明: String\n  -生活服务说明: String\n  +判断位置是否可用(): boolean\n  +判断配套是否可用(): boolean\n  +生成位置配套说明(): String\n}\n\n用户 &lt;|-- 普通用户 : 泛化\n\n普通用户 \&quot;1\&quot; --&gt; \&quot;1\&quot; 查询房源边界类 : 关联\n\n查询房源边界类 &lt;|-- 房源统计概况页面 : 泛化\n查询房源边界类 &lt;|-- 房源列表页面 : 泛化\n查询房源边界类 &lt;|-- 房源详情页面 : 泛化\n\n查询房源边界类 \&quot;1\&quot; --&gt; \&quot;1\&quot; 查询控制器 : 关联\n\n查询控制器 \&quot;1\&quot; ..&gt; \&quot;1\&quot; I房源查询服务 : 依赖\n查询控制器 \&quot;1\&quot; ..&gt; \&quot;1\&quot; I地图服务 : 依赖\n\nI房源查询服务 &lt;|.. 房源查询服务 : 实现\nI地图服务 &lt;|.. 地图服务适配类 : 实现\n\n房源统计概况页面 \&quot;1\&quot; --&gt; \&quot;1\&quot; 房源统计概况 : 关联\n房源列表页面 \&quot;1\&quot; --&gt; \&quot;1\&quot; 筛选条件 : 关联\n房源列表页面 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 房源 : 关联\n房源详情页面 \&quot;1\&quot; --&gt; \&quot;1\&quot; 房源 : 关联\n房源详情页面 \&quot;1\&quot; --&gt; \&quot;0..1\&quot; 房源详情 : 关联\n房源详情页面 \&quot;1\&quot; --&gt; \&quot;0..1\&quot; 详细位置和周边配套 : 关联\n\n普通用户 \&quot;1\&quot; --&gt; \&quot;0..*\&quot; 筛选条件 : 关联\n\n房源查询服务 \&quot;1\&quot; ..&gt; \&quot;1\&quot; 房源统计概况 : 依赖\n房源查询服务 \&quot;1\&quot; ..&gt; \&quot;1\&quot; 筛选条件 : 依赖\n房源查询服务 \&quot;1\&quot; ..&gt; \&quot;0..*\&quot; 房源 : 依赖\n房源查询服务 \&quot;1\&quot; ..&gt; \&quot;0..1\&quot; 房源详情 : 依赖\n\n地图服务适配类 \&quot;1\&quot; ..&gt; \&quot;0..1\&quot; 详细位置和周边配套 : 依赖\n\n城市 \&quot;1\&quot; o-- \&quot;1..*\&quot; 地区 : 聚合\n地区 \&quot;1\&quot; o-- \&quot;0..*\&quot; 小区 : 聚合\n小区 \&quot;1\&quot; o-- \&quot;0..*\&quot; 房源 : 聚合\n\n房源 \&quot;1\&quot; *-- \&quot;0..1\&quot; 房源详情 : 组合\n房源 \&quot;1\&quot; *-- \&quot;0..1\&quot; 详细位置和周边配套 : 组合\n\n筛选条件 \&quot;1\&quot; ..&gt; \&quot;0..*\&quot; 房源 : 依赖\n房源统计概况 \&quot;1\&quot; ..&gt; \&quot;0..*\&quot; 房源 : 依赖&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="7eVDWPtCOEXNINBA27vf-1510">
