          <mxCell edge="1" parent="rvZjHZs7JUC4JIlDZKwR-5694" source="rvZjHZs7JUC4JIlDZKwR-5772" style="startArrow=none;endArrow=none;strokeColor=light-dark(#333333,#cccccc);html=1;fontSize=16;labelBackgroundColor=light-dark(#ECECFF,#1f2020);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontColor=light-dark(#333333,#cccccc);exitX=1;exitY=1;rounded=0;edgeStyle=orthogonalEdgeStyle;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="rvZjHZs7JUC4JIlDZKwR-5820">
