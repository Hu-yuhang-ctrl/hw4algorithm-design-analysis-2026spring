        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n\n    Start((开始)) --&gt; A[\&quot;进入房价预测功能\&quot;]\n    A --&gt; B[\&quot;系统加载预测输入项与候选项\&quot;]\n    B --&gt; C[\&quot;填写或调整房源特征\&quot;]\n    C --&gt; D[\&quot;确认提交预测请求\&quot;]\n    D --&gt; E[\&quot;系统获取用户填写的房源特征信息\&quot;]\n\n    E --&gt; F[\&quot;系统检查必填房源特征是否完整\&quot;]\n    F --&gt; G{\&quot;必填信息是否完整？\&quot;}\n\n    G -- 否 --&gt; G1[\&quot;提示补充必填房源特征信息\&quot;]\n    G1 --&gt; R[\&quot;返回房源特征填写环节\&quot;]\n    R --&gt; C\n\n    G -- 是 --&gt; H[\&quot;系统校验必填房源特征是否合法\&quot;]\n    H --&gt; I{\&quot;必填信息是否合法？\&quot;}\n\n    I -- 否 --&gt; I1[\&quot;提示修改不合法的必填房源特征\&quot;]\n    I1 --&gt; R\n\n    I -- 是 --&gt; J[\&quot;系统判断是否填写选填房源特征\&quot;]\n    J --&gt; K{\&quot;是否填写选填项？\&quot;}\n\n    K -- 否 --&gt; N[\&quot;整理有效房源特征\&quot;]\n\n    K -- 是 --&gt; L[\&quot;系统校验已填写的选填房源特征是否合法\&quot;]\n    L --&gt; M{\&quot;选填信息是否合法？\&quot;}\n\n    M -- 否 --&gt; M1[\&quot;提示修改或清空不合法的选填房源特征\&quot;]\n    M1 --&gt; R\n\n    M -- 是 --&gt; N[\&quot;整理有效房源特征\&quot;]\n\n    N --&gt; O[\&quot;对类别特征进行编码处理\&quot;]\n    O --&gt; P[\&quot;对数值特征进行标准化处理\&quot;]\n    P --&gt; Q[\&quot;生成模型输入数据\&quot;]\n\n    Q --&gt; S[\&quot;系统加载房价预测模型和特征处理规则\&quot;]\n    S --&gt; T{\&quot;预测模型是否可用？\&quot;}\n\n    T -- 否 --&gt; T1[\&quot;提示预测模型暂不可用\&quot;]\n    T1 --&gt; T2{\&quot;是否调整条件后重试？\&quot;}\n    T2 -- 是 --&gt; R\n    T2 -- 否 --&gt; End((结束))\n\n    T -- 是 --&gt; U[\&quot;执行房价预测计算\&quot;]\n    U --&gt; V{\&quot;模型是否成功返回预测结果？\&quot;}\n\n    V -- 否 --&gt; V1[\&quot;提示预测失败\&quot;]\n    V1 --&gt; V2[\&quot;提示稍后重试或修改预测条件\&quot;]\n    V2 --&gt; R\n\n    V -- 是 --&gt; W[\&quot;生成预测房价\&quot;]\n    W --&gt; X[\&quot;生成预测结果说明\&quot;]\n    X --&gt; Y[\&quot;保存本次预测记录\&quot;]\n    Y --&gt; Z[\&quot;展示预测结果及说明\&quot;]\n\n    Z --&gt; AA{\&quot;是否重新调整预测条件？\&quot;}\n\n    AA -- 是 --&gt; AB[\&quot;修改房源特征信息\&quot;]\n    AB --&gt; AC[\&quot;重新提交预测请求\&quot;]\n    AC --&gt; E\n\n    AA -- 否 --&gt; End&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="IWdd7cq-W41f84VaV7Cw-171">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=1;groupPadding=20;" vertex="1">
            <mxGeometry height="11340" width="2393.5" as="geometry" />
          </mxCell>
        </UserObject>
